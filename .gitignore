# Environment files (defense in depth — apps/web/.gitignore also covers app-local .env)
.env
.env.*
!.env.example

# Repo root must stay deps-free — all Node deps live in apps/web/.
# If you see node_modules/ here, someone ran `npm install` at the root by mistake.
/node_modules

# Next.js app (`apps/web/`)
apps/web/node_modules
apps/web/.next
apps/web/out
apps/web/.env*.local
apps/web/npm-debug.log*
apps/web/.vercel

# OS / editor
.DS_Store
Thumbs.db
*.swp

# Cursor IDE debug logs
.cursor/debug*.log

# Local command output / debug artifacts
apps/web/.lint-out.txt
debug-*.log

.vercel
