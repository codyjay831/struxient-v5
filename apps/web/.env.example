# Database connection string
DATABASE_URL="postgresql://postgres:postgres_password@localhost:5432/struxient?schema=public"

# Optional: Google Maps JavaScript API key (Places) for public intake address autocomplete only.
# Restrict by HTTP referrer in Google Cloud Console. Not required for manual address entry.
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Storage Configuration
# STORAGE_PROVIDER: local | gcs
STORAGE_PROVIDER=local

# Google Cloud Storage (required if STORAGE_PROVIDER=gcs in production)
# GCS_BUCKET_NAME=your-bucket-name
# GCP_PROJECT_ID=your-project-id
# GCS_SIGNED_URL_EXPIRES_SECONDS=300

# Notifications (Resend)
# Optional: Without this key, quote send/accept actions still work but email notifications are skipped (logged to console).
# Get your API key from https://resend.com/api-keys
# RESEND_API_KEY=re_123456789

# Authentication (Auth.js) — REQUIRED in production (min 32 characters)
# AUTH_SECRET=your-auth-secret-here

# Distributed rate limiting — REQUIRED in production for multi-instance deployments
# REDIS_URL=redis://localhost:6379

# Beta launch: set to "true" to allow open sign-up in production (default: invite-only in prod)
# BETA_SIGNUP_ENABLED=true
# BETA_DEFAULT_DAYS=30
# BETA_INVITE_EXPIRY_DAYS=14
# BETA_DEFAULT_AI_UNITS=50

# Struxient SaaS billing (Stripe)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRUXIENT_BASE_PRICE_ID=price_...
# STRUXIENT_TRIAL_DAYS=14
# STRUXIENT_BASE_PLAN_DISPLAY_CENTS=9900
# AI_INCLUDED_UNITS=500
# AI_OVERAGE_PRICE_PER_UNIT_CENTS=2
# Log real Gemini tokens without decrementing allowance counters (set 0 to enforce billing)
# AI_METERING_SHADOW=1

# App URL — REQUIRED in production
NEXT_PUBLIC_APP_URL=http://localhost:3001

# AI Configuration
# GEMINI_API_KEY=your-gemini-api-key-here
# Optional: override Gemini model. Default is gemini-2.5-flash.
# GEMINI_MODEL=gemini-2.5-flash
