generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                        String                     @id @default(cuid())
  name                      String
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  /// Lowercase public handle for `/request/[slug]` — optional until configured.
  slug                      String?                    @unique
  /// IANA timezone for deadline date-only EOD resolution and schedule display.
  timezone                  String                     @default("America/Los_Angeles")
  attachments               Attachment[]
  customers                 Customer[]
  customerServiceLocations  CustomerServiceLocation[]
  dailyJobLogs              DailyJobLog[]
  intakeFormDefinitions     IntakeFormDefinition[]
  jobs                      Job[]
  jobActivities             JobActivity[]
  jobIssues                 JobIssue[]
  jobRecoveryFlows          JobRecoveryFlow[]
  jobPaymentRequirements    JobPaymentRequirement[]
  jobVisits                 JobVisit[]
  jobScheduleEvents         JobScheduleEvent[]
  leads                     Lead[]
  leadCustomFieldDefs       LeadCustomFieldDef[]
  leadVisitRequests         LeadVisitRequest[]
  scheduleBlocks            ScheduleBlock[]
  lineItemTemplates         LineItemTemplate[]
  memberships               Membership[]
  publicRequestSettings     PublicRequestSettings?
  quotes                    Quote[]
  quoteChangeRequests       QuoteChangeRequest[]
  quoteCheckpoints          QuoteCheckpoint[]
  quoteShareTokens          QuoteShareToken[]
  notificationEvents        NotificationEvent[]
  stages                    Stage[]
  taskTemplates             TaskTemplate[]
  tags                      Tag[]
  clarificationQuestionSets ClarificationQuestionSet[]
  workstationSettings       WorkstationSettings?
}

model Stage {
  id                      String                   @id @default(cuid())
  organizationId          String
  name                    String
  sortOrder               Int                      @default(0)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  archivedAt              DateTime?
  jobStages               JobStage[]
  jobTasks                JobTask[]
  lineItemTemplateTasks   LineItemTemplateTask[]
  quoteLineExecutionTasks QuoteLineExecutionTask[]
  organization            Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  taskTemplates           TaskTemplate[]
  paymentScheduleItems    PaymentScheduleItem[]

  @@index([organizationId])
  @@index([organizationId, sortOrder])
}

model WorkstationSettings {
  id                   String       @id @default(cuid())
  organizationId       String       @unique
  showQuickActions     Boolean      @default(true)
  /// JSON array of visible action keys: ["new-intake", "new-quote", "browse-jobs"]
  quickActionsJson     Json         @default("[\"new-intake\", \"new-quote\", \"browse-jobs\"]")
  urgentThresholdHours Int          @default(24)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

/// V1 contractor-configurable copy for the Public Intake Form — not a form-builder schema.
model PublicRequestSettings {
  id                      String       @id @default(cuid())
  organizationId          String       @unique
  enabled                 Boolean      @default(true)
  formTitle               String       @default("Request service")
  introMessage            String?
  emergencyWarningText    String?
  submitButtonText        String       @default("Send request")
  /// JSON array of `{ "value": "slug-key", "label": "Customer label" }` — validated server-side.
  requestTypeOptionsJson  Json         @default("[]")
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
  /// JSON object mapping requestType value to array of LineItemTemplate ids: `{ "roof-repair": ["id1", "id2"] }`
  instantQuoteConfigJson  Json         @default("{}")
  instantQuoteEnabled     Boolean      @default(true)
  offerings               String[]     @default([])
  showInstantQuoteDetails Boolean      @default(true)
  organization            Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Customer {
  id               String                    @id @default(cuid())
  organizationId   String
  displayName      String
  companyName      String?
  email            String?
  phone            String?
  notes            String?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  attachments      Attachment[]
  organization     Organization              @relation(fields: [organizationId], references: [id])
  serviceLocations CustomerServiceLocation[]
  jobs             Job[]
  leads            Lead[]
  quotes           Quote[]

  @@index([organizationId])
}

/// Canonical service location record (legacy model name retained for safe additive migration).
model CustomerServiceLocation {
  id                 String                        @id @default(cuid())
  organizationId     String
  customerId         String?
  formattedAddress   String
  addressLine1       String                        @default("")
  addressLine2       String                        @default("")
  city               String                        @default("")
  state              String                        @default("")
  postalCode         String                        @default("")
  country            String                        @default("")
  googlePlaceId      String                        @default("")
  latitude           Float?
  longitude          Float?
  source             CustomerServiceLocationSource
  /// Normalized deterministic key for dedup/reconciliation.
  addressFingerprint String                        @default("")
  label              String?
  isPrimary          Boolean                       @default(false)
  /// Set when property details must be re-reviewed due to material address edits.
  staleAt            DateTime?
  staleReason        String?
  createdAt          DateTime                      @default(now())
  updatedAt          DateTime                      @updatedAt
  createdFromLeadId  String?
  createdFromLead    Lead?                         @relation("ServiceLocationCreatedFromLead", fields: [createdFromLeadId], references: [id])
  customer           Customer?                     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  leads              Lead[]                        @relation("LeadServiceLocation")
  quotes             Quote[]                       @relation("QuoteServiceLocation")
  jobs               Job[]                         @relation("JobServiceLocation")
  organization       Organization                  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([customerId])
  @@index([customerId, isPrimary])
  @@index([createdFromLeadId])
  @@index([organizationId, addressFingerprint])
  @@index([organizationId, googlePlaceId])
}

model User {
  id                     String               @id @default(cuid())
  email                  String?              @unique
  name                   String?
  passwordHash           String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  emailVerified          DateTime?
  image                  String?
  accounts               Account[]
  uploadedAttachments    Attachment[]         @relation("UploadedAttachments")
  reviewedDailyJobLogs   DailyJobLog[]        @relation("ReviewedBy")
  jobActivities          JobActivity[]
  jobIssues              JobIssue[]
  completedTasks         JobTask[]            @relation("CompletedTasks")
  assignedTasks          JobTask[]            @relation("AssignedTasks")
  assignedVisits         JobVisit[]           @relation("AssignedVisits")
  leadScheduleEvents     JobScheduleEvent[]   @relation("LeadScheduleEvents")
  scheduleBlocks         ScheduleBlock[]
  notificationEvents     NotificationEvent[]
  leadEvents             LeadEvent[]
  memberships            Membership[]
  resolvedChangeRequests QuoteChangeRequest[]
  sessions               Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Membership {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           StaffRole    @default(FIELD)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

model Lead {
  id                      String                    @id @default(cuid())
  organizationId          String
  customerId              String?
  serviceLocationId       String?
  status                  LeadStatus                @default(NEW)
  channel                 LeadChannel               @default(MANUAL)
  contact                 Json
  request                 Json
  address                 Json?
  signals                 Json?
  formDefinitionId        String?
  formSnapshot            Json?
  raw                     Json?
  assignedToId            String?
  publicClientKey         String?
  convertedAt             DateTime?
  closeReason             LeadCloseReason?
  followUpAt              DateTime?
  closedAt                DateTime?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  attachments             Attachment[]
  createdServiceLocations CustomerServiceLocation[] @relation("ServiceLocationCreatedFromLead")
  jobs                    Job[]
  customer                Customer?                 @relation(fields: [customerId], references: [id])
  serviceLocation         CustomerServiceLocation?  @relation("LeadServiceLocation", fields: [serviceLocationId], references: [id], onDelete: SetNull)
  organization            Organization              @relation(fields: [organizationId], references: [id])
  customFieldValues       LeadCustomFieldValue[]
  events                  LeadEvent[]
  visitRequests           LeadVisitRequest[]
  quotes                  Quote[]

  @@unique([organizationId, publicClientKey])
  @@index([organizationId, status])
  @@index([serviceLocationId])
}

model Quote {
  id                    String                   @id @default(cuid())
  organizationId        String
  customerId            String?
  serviceLocationId     String?
  status                QuoteStatus              @default(DRAFT)
  title                 String
  internalNotes         String?
  subtotalCents         Int                      @default(0)
  totalCents            Int                      @default(0)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  customerDocumentTitle String?
  lastSentEmailAt       DateTime?
  leadId                String?
  presentation          Json?
  attachments           Attachment[]
  job                   Job?
  customer              Customer?                @relation(fields: [customerId], references: [id])
  lead                  Lead?                    @relation(fields: [leadId], references: [id])
  serviceLocation       CustomerServiceLocation? @relation("QuoteServiceLocation", fields: [serviceLocationId], references: [id], onDelete: SetNull)
  organization          Organization             @relation(fields: [organizationId], references: [id])
  changeRequests        QuoteChangeRequest[]
  checkpoints           QuoteCheckpoint[]
  lineItems             QuoteLineItem[]
  paymentSchedule       PaymentScheduleItem[]
  shareToken            QuoteShareToken?

  @@index([organizationId])
  @@index([customerId])
  @@index([leadId])
  @@index([serviceLocationId])
  @@index([status])
}

model QuoteShareToken {
  id             String       @id @default(cuid())
  organizationId String
  quoteId        String       @unique
  token          String       @unique
  createdAt      DateTime     @default(now())
  expiresAt      DateTime?
  revokedAt      DateTime?
  lastViewedAt   DateTime?
  acceptedAt     DateTime?
  acceptedByName String?
  acceptedFromIp String?
  userAgent      String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  quote          Quote        @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([token])
}

model QuoteView {
  id             String   @id @default(cuid())
  organizationId String
  quoteId        String
  token          String
  viewedAt       DateTime @default(now())
  ip             String?
  userAgent      String?

  @@index([organizationId])
  @@index([quoteId])
  @@index([token])
}

model QuoteChangeRequest {
  id               String       @id @default(cuid())
  organizationId   String
  quoteId          String
  token            String
  message          String
  submittedFromIp  String?
  userAgent        String?
  createdAt        DateTime     @default(now())
  resolvedAt       DateTime?
  resolvedByUserId String?
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  quote            Quote        @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  resolvedBy       User?        @relation(fields: [resolvedByUserId], references: [id])

  @@index([quoteId])
  @@index([organizationId, createdAt])
}

/// Immutable staff-only proof of what the customer-facing proposal contained at a commitment moment (send, acceptance).
/// Quote status advances with Send (→ SENT) and staff-recorded approval (→ APPROVED) in v1; checkpoints store commercial projection only.
/// Future runtime jobs materialize from approved commercial baseline plus internal execution planning — not from checkpoint rows alone.
model QuoteCheckpoint {
  id                      String                @id @default(cuid())
  organizationId          String
  quoteId                 String
  kind                    QuoteCheckpointKind
  sequence                Int
  schemaVersion           Int
  snapshotJson            Json
  staffOnlyJson           Json?
  /// Quote row `updatedAt` at capture time — staff context for drift vs proof.
  quoteUpdatedAtAtCapture DateTime?
  createdAt               DateTime              @default(now())
  source                  QuoteCheckpointSource @default(STAFF)
  organization            Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  quote                   Quote                 @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@unique([quoteId, kind, sequence])
  @@index([organizationId])
  @@index([quoteId, kind])
}

/// Reusable commercial line presets for an organization. Applying copies values onto [QuoteLineItem];
/// quotes never read live template fields for pricing after insert.
model LineItemTemplate {
  id                               String                 @id @default(cuid())
  organizationId                   String
  description                      String
  defaultQuantity                  Decimal                @db.Decimal(18, 6)
  defaultUnitAmountCents           Int
  defaultInternalNotes             String?
  archivedAt                       DateTime?
  createdAt                        DateTime               @default(now())
  updatedAt                        DateTime               @updatedAt
  defaultCustomerExcludedNotes     String?
  defaultCustomerIncludedNotes     String?
  defaultCustomerPresentationGroup String?
  defaultCustomerScopeDescription  String?
  defaultCustomerScopeTitle        String?
  priceBufferPercentage            Int                    @default(0)
  tags                             Tag[]                  @relation("LineItemTemplateToTag")
  organization                     Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  defaultExecutionTasks            LineItemTemplateTask[]
  quoteLineItems                   QuoteLineItem[]

  @@index([organizationId])
  @@index([organizationId, archivedAt])
}

/// Org-scoped reusable task presets (library). Quote/job rows copy fields from templates when applied — not live-linked.
model TaskTemplate {
  id                      String                   @id @default(cuid())
  organizationId          String
  title                   String
  category                TaskTemplateCategory
  instructions            String?
  archivedAt              DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  requirementsJson        Json                     @default("{}")
  /// Reserved for future assignment logic.
  assigneeRole            StaffRole?
  /// Reserved for future job costing.
  costBudgetCents         Int?
  /// Reserved for future estimation logic.
  estimatedMinutes        Int?
  hardSignal              Boolean                  @default(false)
  /// Reserved for future parts/materials logic.
  partsRequiredJson       Json?
  providesSignals         String[]                 @default([])
  requiresSignals         String[]                 @default([])
  tags                    Tag[]                    @relation("TaskTemplateToTag")
  stageId                 String?
  jobTaskCopies           JobTask[]
  lineItemTemplateTasks   LineItemTemplateTask[]
  quoteLineExecutionTasks QuoteLineExecutionTask[]
  organization            Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stage                   Stage?                   @relation(fields: [stageId], references: [id])

  @@index([organizationId])
  @@index([organizationId, archivedAt])
}

/// Optional default execution on a saved line item — snapshot fields; not live-linked to [TaskTemplate] or quotes.
model LineItemTemplateTask {
  id                   String                     @id @default(cuid())
  lineItemTemplateId   String
  sourceType           LineItemTemplateTaskSource
  sourceTaskTemplateId String?
  title                String
  category             TaskTemplateCategory
  instructions         String?
  sortOrder            Int                        @default(0)
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  requirementsJson     Json                       @default("{}")
  /// Reserved for future assignment logic.
  assigneeRole         StaffRole?
  /// Reserved for future job costing.
  costBudgetCents      Int?
  /// Reserved for future estimation logic.
  estimatedMinutes     Int?
  hardSignal           Boolean                    @default(false)
  /// Reserved for future parts/materials logic.
  partsRequiredJson    Json?
  providesSignals      String[]                   @default([])
  requiresSignals      String[]                   @default([])
  stageId              String?
  lineItemTemplate     LineItemTemplate           @relation(fields: [lineItemTemplateId], references: [id], onDelete: Cascade)
  sourceTaskTemplate   TaskTemplate?              @relation(fields: [sourceTaskTemplateId], references: [id])
  stage                Stage?                     @relation(fields: [stageId], references: [id])
  quoteLineCopies      QuoteLineExecutionTask[]

  @@index([lineItemTemplateId, sortOrder])
}

/// Line items are always loaded through [Quote] scoped by [Quote.organizationId].
/// No denormalized organizationId here—avoids redundant writes and drift.
model QuoteLineItem {
  id                        String                   @id @default(cuid())
  quoteId                   String
  sortOrder                 Int                      @default(0)
  description               String
  quantity                  Decimal                  @db.Decimal(18, 6)
  unitAmountCents           Int
  lineTotalCents            Int
  internalNotes             String?
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt
  sourceLineItemTemplateId  String?
  customerExcludedNotes     String?
  customerIncludedNotes     String?
  customerPresentationGroup String?
  customerScopeDescription  String?
  customerScopeTitle        String?
  jobStageCopies            JobStage[]
  jobTaskCopies             JobTask[]
  draftExecutionTasks       QuoteLineExecutionTask[]
  clarifications            QuoteLineClarification[]
  quote                     Quote                    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  sourceLineItemTemplate    LineItemTemplate?        @relation(fields: [sourceLineItemTemplateId], references: [id])

  @@index([quoteId])
  @@index([sourceLineItemTemplateId])
}

/// Org-scoped reusable scope clarification set with versioned questions/options.
model ClarificationQuestionSet {
  id             String                         @id @default(cuid())
  organizationId String
  key            String
  version        Int
  label          String
  status         ClarificationQuestionSetStatus @default(draft)
  description    String?
  aliases        String[]                       @default([])
  keywords       String[]                       @default([])
  archivedAt     DateTime?
  mergedIntoId   String?
  createdAt      DateTime                       @default(now())
  updatedAt      DateTime                       @updatedAt
  organization   Organization                   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  mergedInto     ClarificationQuestionSet?      @relation("ClarificationQuestionSetMerge", fields: [mergedIntoId], references: [id])
  mergedFrom     ClarificationQuestionSet[]     @relation("ClarificationQuestionSetMerge")
  questions      ClarificationQuestion[]
  tags           Tag[]                          @relation("ClarificationQuestionSetToTag")
  lineAnswers    QuoteLineClarification[]

  @@unique([organizationId, key, version])
  @@index([organizationId])
  @@index([organizationId, key])
  @@index([organizationId, status])
}

model ClarificationQuestion {
  id             String                   @id @default(cuid())
  questionSetId  String
  key            String
  label          String
  inputType      ClarificationInputType
  helpText       String?
  allowOther     Boolean                  @default(false)
  unit           String?
  customerFacing Boolean                  @default(false)
  sortOrder      Int                      @default(0)
  aliases        String[]                 @default([])
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  questionSet    ClarificationQuestionSet @relation(fields: [questionSetId], references: [id], onDelete: Cascade)
  options        ClarificationOption[]

  @@unique([questionSetId, key])
  @@index([questionSetId, sortOrder])
}

model ClarificationOption {
  id         String                @id @default(cuid())
  questionId String
  key        String
  label      String
  aliases    String[]              @default([])
  sortOrder  Int                   @default(0)
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  question   ClarificationQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, key])
  @@index([questionId, sortOrder])
}

/// Durable per-line clarification answers with version-safe snapshots.
model QuoteLineClarification {
  id                 String                    @id @default(cuid())
  quoteLineItemId    String
  clarificationSetId String?
  questionSetKey     String
  questionSetVersion Int
  answersJson        Json
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  quoteLineItem      QuoteLineItem             @relation(fields: [quoteLineItemId], references: [id], onDelete: Cascade)
  clarificationSet   ClarificationQuestionSet? @relation(fields: [clarificationSetId], references: [id], onDelete: SetNull)

  @@unique([quoteLineItemId, questionSetKey, questionSetVersion])
  @@index([quoteLineItemId])
  @@index([questionSetKey, questionSetVersion])
}

/// Draft internal execution tasks for a quote line — independent from [LineItemTemplateTask] and [TaskTemplate] after copy.
model QuoteLineExecutionTask {
  id                           String                     @id @default(cuid())
  quoteLineItemId              String
  sourceLineItemTemplateTaskId String?
  sourceTaskTemplateId         String?
  sourceType                   LineItemTemplateTaskSource
  title                        String
  category                     TaskTemplateCategory
  instructions                 String?
  sortOrder                    Int                        @default(0)
  createdAt                    DateTime                   @default(now())
  updatedAt                    DateTime                   @updatedAt
  requirementsJson             Json                       @default("{}")
  /// Reserved for future assignment logic.
  assigneeRole                 StaffRole?
  /// Reserved for future job costing.
  costBudgetCents              Int?
  /// Reserved for future estimation logic.
  estimatedMinutes             Int?
  hardSignal                   Boolean                    @default(false)
  /// Reserved for future parts/materials logic.
  partsRequiredJson            Json?
  providesSignals              String[]                   @default([])
  requiresSignals              String[]                   @default([])
  stageId                      String?
  jobTaskCopies                JobTask[]
  quoteLineItem                QuoteLineItem              @relation(fields: [quoteLineItemId], references: [id], onDelete: Cascade)
  sourceLineItemTemplateTask   LineItemTemplateTask?      @relation(fields: [sourceLineItemTemplateTaskId], references: [id])
  sourceTaskTemplate           TaskTemplate?              @relation(fields: [sourceTaskTemplateId], references: [id])
  stage                        Stage?                     @relation(fields: [stageId], references: [id])

  @@index([quoteLineItemId, sortOrder])
}

model PaymentScheduleItem {
  id            String                    @id @default(cuid())
  quoteId       String
  title         String // e.g. "Deposit", "Progress Payment", "Final Balance"
  amountCents   Int?
  percentage    Decimal?                  @db.Decimal(5, 2) // Optional: for % based schedules
  sortOrder     Int                       @default(0)
  // Anchor logic for execution gating
  anchorType    PaymentScheduleAnchorType @default(UPON_APPROVAL)
  anchorStageId String? // Link to a Stage in the library
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  quote         Quote                     @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  anchorStage   Stage?                    @relation(fields: [anchorStageId], references: [id])

  @@index([quoteId])
  @@index([quoteId, sortOrder])
}

/// Runtime job materialized from an APPROVED [Quote] at activation time.
/// Job rows are independent copies — later quote/template edits do not mutate stages or tasks here.
/// One job per quote in V1 (enforced by [@@unique] on [quoteId]).
model Job {
  id                  String                   @id @default(cuid())
  organizationId      String
  quoteId             String                   @unique
  customerId          String?
  serviceLocationId   String?
  title               String
  status              JobStatus                @default(ACTIVE)
  activatedAt         DateTime                 @default(now())
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  leadId              String?
  attachments         Attachment[]
  dailyJobLogs        DailyJobLog[]
  customer            Customer?                @relation(fields: [customerId], references: [id])
  lead                Lead?                    @relation(fields: [leadId], references: [id])
  serviceLocation     CustomerServiceLocation? @relation("JobServiceLocation", fields: [serviceLocationId], references: [id], onDelete: SetNull)
  organization        Organization             @relation(fields: [organizationId], references: [id])
  quote               Quote                    @relation(fields: [quoteId], references: [id])
  activities          JobActivity[]
  issues              JobIssue[]
  recoveryFlows       JobRecoveryFlow[]
  paymentRequirements JobPaymentRequirement[]
  signals             JobSignal[]
  stages              JobStage[]
  tasks               JobTask[]
  visits              JobVisit[]
  scheduleEvents      JobScheduleEvent[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([customerId])
  @@index([leadId])
  @@index([serviceLocationId])
}

/// Per-job fact bus for Signal-based readiness.
model JobSignal {
  id               String   @id @default(cuid())
  jobId            String
  name             String
  publishedAt      DateTime @default(now())
  /// Optional ID of the task that published this signal.
  sourceJobTaskId  String?
  /// Optional ID of the stage that published this signal.
  sourceJobStageId String?
  job              Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, name])
  @@index([jobId])
}

/// Stage on a job — materialized from the org-scoped Stage table at activation.
model JobStage {
  id                    String                  @id @default(cuid())
  jobId                 String
  title                 String
  /// Position within the job.
  sortOrder             Int                     @default(0)
  /// Source quote line id at activation; SetNull if the line is later removed.
  sourceQuoteLineItemId String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  providesSignals       String[]                @default([])
  requiresSignals       String[]                @default([])
  stageId               String?
  issues                JobIssue[]
  paymentRequirements   JobPaymentRequirement[]
  job                   Job                     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  sourceQuoteLineItem   QuoteLineItem?          @relation(fields: [sourceQuoteLineItemId], references: [id])
  stage                 Stage?                  @relation(fields: [stageId], references: [id])
  tasks                 JobTask[]

  @@index([jobId])
  @@index([jobId, sortOrder])
  @@index([sourceQuoteLineItemId])
}

/// Runtime task on a job — copied from a quote line execution task at activation; later quote edits do not mutate this row.
/// Lineage fields use SetNull so source deletes do not orphan the runtime row.
model JobTask {
  id                             String                     @id @default(cuid())
  jobId                          String
  jobStageId                     String
  sourceQuoteLineItemId          String?
  sourceQuoteLineExecutionTaskId String?
  sourceTaskTemplateId           String?
  sourceType                     LineItemTemplateTaskSource
  title                          String
  category                       TaskTemplateCategory
  instructions                   String?
  status                         JobTaskStatus              @default(TODO)
  sortOrder                      Int                        @default(0)
  createdAt                      DateTime                   @default(now())
  updatedAt                      DateTime                   @updatedAt
  sourceJobIssueId               String?
  recoveryFlowId                 String?
  recoveryFlowOrder              Int                        @default(0)
  completedAt                    DateTime?
  completedByUserId              String?
  assignedUserId                 String?
  completionNote                 String?
  completionRequirementsJson     Json                       @default("{}")
  actualMinutes                  Int?
  dueAt                          DateTime?
  /// @deprecated Legacy calendar fields — use JobScheduleEvent after canonical cutover.
  scheduledStartAt               DateTime?
  /// @deprecated Legacy calendar fields — use JobScheduleEvent after canonical cutover.
  scheduledEndAt                 DateTime?
  /// @deprecated Replaced by dueMode + dueAnchor + dueOffsetDays.
  dueOffsetMinutesAfterReady     Int?
  dueMode                        TaskDueMode                @default(NONE)
  dueAnchor                      TaskDueAnchor?
  dueOffsetDays                  Int?
  dueGranularity                 TaskDueGranularity?
  dueResolvedAt                  DateTime?
  dueFirstReadyAt                DateTime?
  schedulingRequirement          TaskSchedulingRequirement  @default(NONE)
  /// Reserved for future assignment logic.
  assigneeRole                   StaffRole?
  /// Reserved for future job costing.
  costBudgetCents                Int?
  /// Reserved for future estimation logic.
  estimatedMinutes               Int?
  hardSignal                     Boolean                    @default(false)
  /// Reserved for future parts/materials logic.
  partsRequiredJson              Json?
  providesSignals                String[]                   @default([])
  requiresSignals                String[]                   @default([])
  stageId                        String?
  attachments                    Attachment[]
  issues                         JobIssue[]
  completedByUser                User?                      @relation("CompletedTasks", fields: [completedByUserId], references: [id])
  assignedUser                   User?                      @relation("AssignedTasks", fields: [assignedUserId], references: [id])
  job                            Job                        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobStage                       JobStage                   @relation(fields: [jobStageId], references: [id], onDelete: Cascade)
  recoveryFlow                   JobRecoveryFlow?           @relation(fields: [recoveryFlowId], references: [id])
  sourceJobIssue                 JobIssue?                  @relation("IssueFollowUpTask", fields: [sourceJobIssueId], references: [id])
  sourceQuoteLineExecutionTask   QuoteLineExecutionTask?    @relation(fields: [sourceQuoteLineExecutionTaskId], references: [id])
  sourceQuoteLineItem            QuoteLineItem?             @relation(fields: [sourceQuoteLineItemId], references: [id])
  sourceTaskTemplate             TaskTemplate?              @relation(fields: [sourceTaskTemplateId], references: [id])
  stage                          Stage?                     @relation(fields: [stageId], references: [id])
  scheduleEventLinks             JobScheduleEventTask[]

  @@index([jobId])
  @@index([jobStageId, sortOrder])
  @@index([recoveryFlowId])
  @@index([assignedUserId])
  @@index([dueAt])
  @@index([scheduledStartAt])
  @@index([schedulingRequirement])
}

/// Canonical job-related calendar commitment (appointment, crew block, inspection window, etc.).
model JobScheduleEvent {
  id             String                 @id @default(cuid())
  organizationId String
  jobId          String
  kind           JobScheduleEventKind
  status         JobScheduleEventStatus @default(TENTATIVE)
  title          String?
  startAt        DateTime
  endAt          DateTime
  leadUserId     String?
  notes          String?
  /// Bridge to legacy JobVisit row during migration; null for new-only events.
  legacyVisitId  String?                @unique
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  job            Job                    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  leadUser       User?                  @relation("LeadScheduleEvents", fields: [leadUserId], references: [id], onDelete: SetNull)
  taskLinks      JobScheduleEventTask[]

  @@index([organizationId])
  @@index([jobId])
  @@index([leadUserId])
  @@index([status])
  @@index([startAt])
  @@index([endAt])
}

model JobScheduleEventTask {
  id                 String           @id @default(cuid())
  jobScheduleEventId String
  jobTaskId          String
  createdAt          DateTime         @default(now())
  jobScheduleEvent   JobScheduleEvent @relation(fields: [jobScheduleEventId], references: [id], onDelete: Cascade)
  jobTask            JobTask          @relation(fields: [jobTaskId], references: [id], onDelete: Cascade)

  @@unique([jobScheduleEventId, jobTaskId])
  @@index([jobTaskId])
}

model JobIssue {
  id              String           @id @default(cuid())
  organizationId  String
  jobId           String
  jobStageId      String?
  jobTaskId       String?
  createdByUserId String?
  type            JobIssueType
  severity        JobIssueSeverity @default(BLOCKS_WORK)
  status          JobIssueStatus   @default(OPEN)
  title           String
  description     String?
  resolutionNote  String?
  resolvedAt      DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  createdByUser   User?            @relation(fields: [createdByUserId], references: [id])
  job             Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobStage        JobStage?        @relation(fields: [jobStageId], references: [id])
  jobTask         JobTask?         @relation(fields: [jobTaskId], references: [id])
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  followUpTasks   JobTask[]        @relation("IssueFollowUpTask")
  recoveryFlow    JobRecoveryFlow?

  @@index([organizationId])
  @@index([jobId])
  @@index([organizationId, status])
  @@index([organizationId, severity])
  @@index([jobTaskId])
  @@index([jobStageId])
}

model JobRecoveryFlow {
  id             String                @id @default(cuid())
  organizationId String
  jobId          String
  jobIssueId     String                @unique
  status         JobRecoveryFlowStatus @default(DRAFT)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  // Context fields for failure lineage
  sourceFailedTaskId      String?
  sourceChecklistItemId   String?
  sourcePermitEventId     String?
  sourceInspectionEventId String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  job          Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobIssue     JobIssue     @relation(fields: [jobIssueId], references: [id], onDelete: Cascade)
  tasks        JobTask[]

  @@index([organizationId])
  @@index([jobId])
  @@index([jobIssueId])
}

model JobVisit {
  id               String         @id @default(cuid())
  organizationId   String
  jobId            String
  scheduledStartAt DateTime
  scheduledEndAt   DateTime?
  status           JobVisitStatus @default(SCHEDULED)
  assignedUserId   String?
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  assignedUser     User?          @relation("AssignedVisits", fields: [assignedUserId], references: [id])
  job              Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([jobId])
  @@index([assignedUserId])
  @@index([status])
  @@index([scheduledStartAt])
}

model Attachment {
  id               String           @id @default(cuid())
  organizationId   String
  fileName         String
  fileKey          String
  contentType      String
  fileSize         Int
  quoteId          String?
  jobId            String?
  jobTaskId        String?
  uploadedByUserId String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  status           AttachmentStatus @default(READY)
  customerId       String?
  description      String?
  leadId           String?
  customer         Customer?        @relation(fields: [customerId], references: [id])
  job              Job?             @relation(fields: [jobId], references: [id])
  jobTask          JobTask?         @relation(fields: [jobTaskId], references: [id])
  lead             Lead?            @relation(fields: [leadId], references: [id])
  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  quote            Quote?           @relation(fields: [quoteId], references: [id])
  uploadedByUser   User?            @relation("UploadedAttachments", fields: [uploadedByUserId], references: [id])

  @@index([organizationId])
  @@index([leadId])
  @@index([quoteId])
  @@index([jobId])
  @@index([jobTaskId])
  @@index([customerId])
}

model JobActivity {
  id             String          @id @default(cuid())
  organizationId String
  jobId          String
  actorUserId    String?
  type           JobActivityType
  title          String
  details        String?
  entityType     String?
  entityId       String?
  metadataJson   Json?
  createdAt      DateTime        @default(now())
  actorUser      User?           @relation(fields: [actorUserId], references: [id])
  job            Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([jobId])
  @@index([organizationId, createdAt])
  @@index([jobId, createdAt])
  @@index([entityType, entityId])
}

model DailyJobLog {
  id               String            @id @default(cuid())
  organizationId   String
  jobId            String
  /// Normalized to midnight for v1. Org-timezone-aware date handling can be improved later.
  logDate          DateTime
  summary          String
  internalNotes    String?
  status           DailyJobLogStatus @default(DRAFT)
  reviewedByUserId String?
  reviewedAt       DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  job              Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reviewedByUser   User?             @relation("ReviewedBy", fields: [reviewedByUserId], references: [id])

  @@unique([jobId, logDate])
  @@index([organizationId])
  @@index([jobId])
  @@index([organizationId, logDate])
  @@index([jobId, logDate])
  @@index([status])
}

model JobPaymentRequirement {
  id                          String                      @id @default(cuid())
  organizationId              String
  jobId                       String
  title                       String
  amountCents                 Int?
  status                      JobPaymentRequirementStatus @default(PENDING)
  requiredBeforeStageId       String?
  sourcePaymentScheduleItemId String?
  paidAt                      DateTime?
  waivedAt                    DateTime?
  canceledAt                  DateTime?
  notes                       String?
  createdAt                   DateTime                    @default(now())
  updatedAt                   DateTime                    @updatedAt
  job                         Job                         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  organization                Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  requiredBeforeStage         JobStage?                   @relation(fields: [requiredBeforeStageId], references: [id])

  @@index([organizationId])
  @@index([jobId])
  @@index([organizationId, status])
  @@index([requiredBeforeStageId])
  @@index([sourcePaymentScheduleItemId])
}

model LeadVisitRequest {
  id              String                 @id @default(cuid())
  organizationId  String
  leadId          String
  requestedDate   DateTime?
  requestedWindow String?
  confirmedDate   DateTime?
  status          LeadVisitRequestStatus @default(PENDING)
  notes           String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  lead            Lead                   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  organization    Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([leadId])
  @@index([status])
}

model ScheduleBlock {
  id             String            @id @default(cuid())
  organizationId String
  userId         String?
  title          String
  type           ScheduleBlockType @default(INTERNAL_EVENT)
  startAt        DateTime
  endAt          DateTime?
  allDay         Boolean           @default(false)
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?             @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([type])
  @@index([startAt])
}

model NotificationEvent {
  id             String              @id @default(cuid())
  organizationId String
  userId         String?
  channel        NotificationChannel @default(IN_APP)
  status         NotificationStatus  @default(PENDING)
  kind           String
  title          String
  body           String?
  dedupeKey      String?
  payloadJson    Json?
  sendAt         DateTime?
  sentAt         DateTime?
  failedAt       DateTime?
  errorMessage   String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?               @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([organizationId, dedupeKey])
  @@index([organizationId])
  @@index([userId])
  @@index([status])
  @@index([sendAt])
  @@index([createdAt])
}

model LeadCustomFieldDef {
  id                 String                 @id @default(cuid())
  organizationId     String
  key                String
  label              String
  type               LeadCustomFieldType
  optionsJson        Json?
  isRequired         Boolean                @default(false)
  showOnPublicIntake Boolean                @default(true)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  organization       Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  values             LeadCustomFieldValue[]

  @@unique([organizationId, key])
  @@index([organizationId])
}

model LeadCustomFieldValue {
  id         String             @id @default(cuid())
  leadId     String
  fieldDefId String
  value      String
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  fieldDef   LeadCustomFieldDef @relation(fields: [fieldDefId], references: [id], onDelete: Cascade)
  lead       Lead               @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([leadId, fieldDefId])
  @@index([leadId])
  @@index([fieldDefId])
}

model IntakeFormDefinition {
  id             String       @id @default(cuid())
  organizationId String
  slug           String
  channel        LeadChannel
  name           String
  isPublic       Boolean      @default(true)
  isDefault      Boolean      @default(false)
  schema         Json
  triageRules    Json?
  archivedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model LeadEvent {
  id          String   @id @default(cuid())
  leadId      String
  type        String
  payload     Json
  createdAt   DateTime @default(now())
  actorUserId String?
  actor       User?    @relation(fields: [actorUserId], references: [id])
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

