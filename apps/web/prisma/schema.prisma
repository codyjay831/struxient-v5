// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  OPEN
  QUALIFYING
  CONVERTED
  LOST
  ARCHIVED
}

enum LeadSource {
  PHONE
  EMAIL
  SMS
  WEBSITE
  PUBLIC_REQUEST_LINK
  REFERRAL
  WALK_IN
  MANUAL
  OTHER
}

enum QuoteStatus {
  DRAFT
  SENT
  APPROVED
  ARCHIVED
}

/// Hidden proof records at commitment moments — not a user-managed version system.
/// SEND captures commercial proposal as sent; APPROVAL captures commercial acceptance (no e-sign integration in v1).
/// Checkpoints are not execution or task sources.
enum QuoteCheckpointKind {
  SEND
  APPROVAL
}

/// V1 canonical execution phases — fixed keys for predictable merge later; no freeform stage names on templates yet.
enum ExecutionStageKey {
  intake_review
  site_visit
  pre_install
  permitting
  materials
  installation
  inspection
  corrections
  closeout
}

/// Lightweight task meaning for library entries — categories inform UX only until behavior is earned later.
enum TaskTemplateCategory {
  GENERAL
  PERMIT
  INSPECTION
  MATERIAL
  PAYMENT
  CUSTOMER_COMMUNICATION
  PHOTO_EVIDENCE
  SCHEDULING
}

/// How a default execution row on a saved line item was created — copied from library vs custom one-off.
enum LineItemTemplateTaskSource {
  TASK_TEMPLATE
  CUSTOM
}

/// Staff-facing execution readiness on a quote line — separate from whether draft tasks exist (derived from task rows).
enum QuoteLineExecutionReviewStatus {
  UNREVIEWED
  NO_EXECUTION_NEEDED
}

/// How this quoted scope should land in a future job plan (V1 planning only; no runtime merge here).
enum QuoteLineExecutionMergeMode {
  MERGE_INTO_JOB_STAGES
  KEEP_SEPARATE_BLOCK
}

/// Runtime job lifecycle (V1 minimal — no scheduling, holds, or financial closeout yet).
enum JobStatus {
  ACTIVE
  ARCHIVED
}

enum DailyJobLogStatus {
  DRAFT
  REVIEWED
  VOID
}

/// V1 stage grouping inside a job: SHARED merges across quote lines using canonical phases;
/// SEPARATE_LINE_ITEM keeps one quote line's stages as their own block (one work block per source line).
enum JobStageBlockType {
  SHARED
  SEPARATE_LINE_ITEM
}

/// V1 minimal task progression — no assignments, dependencies, or schedule wiring in this build.
enum JobTaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

model Organization {
  id                    String                 @id @default(cuid())
  name                  String
  /// Lowercase public handle for `/request/[slug]` — optional until configured.
  slug                  String?                @unique
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  memberships           Membership[]
  jobIssues             JobIssue[]
  customers             Customer[]
  leads                 Lead[]
  quotes                Quote[]
  lineItemTemplates     LineItemTemplate[]
  taskTemplates         TaskTemplate[]
  quoteCheckpoints      QuoteCheckpoint[]
  jobs                  Job[]
  jobPaymentRequirements JobPaymentRequirement[]
  jobActivities         JobActivity[]
  dailyJobLogs          DailyJobLog[]
  publicRequestSettings PublicRequestSettings?
}

/// V1 contractor-configurable copy for the Public Intake Form — not a form-builder schema.
model PublicRequestSettings {
  id                       String       @id @default(cuid())
  organizationId           String       @unique
  organization           Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  enabled                  Boolean      @default(true)
  formTitle                String       @default("Request service")
  introMessage             String?
  emergencyWarningText     String?
  submitButtonText         String       @default("Send request")
  /// JSON array of `{ "value": "slug-key", "label": "Customer label" }` — validated server-side.
  requestTypeOptionsJson   Json         @default("[]")
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt
}

model Customer {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  displayName    String
  companyName    String?
  email          String?
  phone          String?
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  leads          Lead[]
  quotes         Quote[]
  jobs           Job[]

  @@index([organizationId])
}

enum StaffRole {
  OWNER
  ADMIN
  OFFICE
  FIELD
  VIEWER
  SUBCONTRACTOR
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  name          String?
  memberships   Membership[]
  jobIssues     JobIssue[]
  jobActivities JobActivity[]
  reviewedDailyJobLogs DailyJobLog[] @relation("ReviewedBy")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Membership {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           StaffRole    @default(FIELD)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

model Lead {
  id             String         @id @default(cuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  customerId     String?
  customer       Customer?      @relation(fields: [customerId], references: [id])
  status         LeadStatus     @default(OPEN)
  source         LeadSource     @default(MANUAL)
  sourceDetail   String?
  title          String
  contactName    String?
  email          String?
  phone          String?
  notes          String?
  convertedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  quotes         Quote[]
  jobs           Job[]

  @@index([organizationId])
  @@index([customerId])
  @@index([status])
  @@index([source])
}

model Quote {
  id               String         @id @default(cuid())
  organizationId   String
  organization     Organization   @relation(fields: [organizationId], references: [id])
  customerId       String?
  customer         Customer?      @relation(fields: [customerId], references: [id])
  leadId           String?
  lead             Lead?          @relation(fields: [leadId], references: [id])
  status                 QuoteStatus    @default(DRAFT)
  title                  String
  customerDocumentTitle  String?
  internalNotes          String?
  subtotalCents      Int            @default(0)
  totalCents         Int            @default(0)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  lineItems          QuoteLineItem[]
  checkpoints        QuoteCheckpoint[]
  job                Job?

  @@index([organizationId])
  @@index([customerId])
  @@index([leadId])
  @@index([status])
}

/// Immutable staff-only proof of what the customer-facing proposal contained at a commitment moment (send, acceptance).
/// Quote status advances with Send (→ SENT) and staff-recorded approval (→ APPROVED) in v1; checkpoints store commercial projection only.
/// Future runtime jobs materialize from approved commercial baseline plus internal execution planning — not from checkpoint rows alone.
model QuoteCheckpoint {
  id                        String              @id @default(cuid())
  organizationId          String
  organization            Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  quoteId                   String
  quote                     Quote               @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  kind                      QuoteCheckpointKind
  sequence                  Int
  schemaVersion             Int
  snapshotJson              Json
  staffOnlyJson             Json?
  /// Quote row `updatedAt` at capture time — staff context for drift vs proof.
  quoteUpdatedAtAtCapture   DateTime?
  createdAt                 DateTime            @default(now())

  @@unique([quoteId, kind, sequence])
  @@index([organizationId])
  @@index([quoteId, kind])
}

/// Reusable commercial line presets for an organization. Applying copies values onto [QuoteLineItem];
/// quotes never read live template fields for pricing after insert.
model LineItemTemplate {
  id                       String          @id @default(cuid())
  organizationId         String
  organization           Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  description            String
  defaultQuantity        Decimal         @db.Decimal(18, 6)
  defaultUnitAmountCents Int
  defaultInternalNotes             String?
  defaultCustomerScopeTitle        String?
  defaultCustomerScopeDescription  String?
  defaultCustomerIncludedNotes     String?
  defaultCustomerExcludedNotes     String?
  defaultCustomerPresentationGroup String?
  archivedAt                       DateTime?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  quoteLineItems         QuoteLineItem[]
  defaultExecutionTasks  LineItemTemplateTask[]

  @@index([organizationId])
  @@index([organizationId, archivedAt])
}

/// Org-scoped reusable task presets (library). Quote/job rows copy fields from templates when applied — not live-linked.
model TaskTemplate {
  id               String               @id @default(cuid())
  organizationId   String
  organization     Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title              String
  stageKey           ExecutionStageKey
  category           TaskTemplateCategory
  instructions       String?
  archivedAt         DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  lineItemTemplateTasks LineItemTemplateTask[]
  quoteLineExecutionTasks QuoteLineExecutionTask[]
  jobTaskCopies      JobTask[]

  @@index([organizationId])
  @@index([organizationId, archivedAt])
}

/// Optional default execution on a saved line item — snapshot fields; not live-linked to [TaskTemplate] or quotes.
model LineItemTemplateTask {
  id                   String                     @id @default(cuid())
  lineItemTemplateId   String
  lineItemTemplate     LineItemTemplate           @relation(fields: [lineItemTemplateId], references: [id], onDelete: Cascade)
  sourceType           LineItemTemplateTaskSource
  sourceTaskTemplateId String?
  sourceTaskTemplate   TaskTemplate?              @relation(fields: [sourceTaskTemplateId], references: [id], onDelete: SetNull)
  title                String
  stageKey             ExecutionStageKey
  category             TaskTemplateCategory
  instructions         String?
  sortOrder            Int                        @default(0)
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  quoteLineCopies      QuoteLineExecutionTask[]

  @@index([lineItemTemplateId, stageKey, sortOrder])
  @@index([lineItemTemplateId, sortOrder])
}

/// Line items are always loaded through [Quote] scoped by [Quote.organizationId].
/// No denormalized organizationId here—avoids redundant writes and drift.
model QuoteLineItem {
  id                       String             @id @default(cuid())
  quoteId                  String
  quote                    Quote              @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  sortOrder                Int                @default(0)
  description                 String
  customerScopeTitle          String?
  customerScopeDescription    String?
  customerIncludedNotes       String?
  customerExcludedNotes       String?
  customerPresentationGroup   String?
  quantity                    Decimal            @db.Decimal(18, 6)
  unitAmountCents             Int
  lineTotalCents              Int
  internalNotes               String?
  sourceLineItemTemplateId String?
  sourceLineItemTemplate   LineItemTemplate?  @relation(fields: [sourceLineItemTemplateId], references: [id], onDelete: SetNull)
  /// Internal planning: whether this line still needs execution review vs explicitly commercial-only.
  executionReviewStatus QuoteLineExecutionReviewStatus @default(UNREVIEWED)
  /// How this scope should group when a job exists — planning metadata only in this build.
  executionMergeMode    QuoteLineExecutionMergeMode   @default(MERGE_INTO_JOB_STAGES)
  /// Work order among lines on this quote for future job sequencing (normalized with peers).
  executionOrder        Int                           @default(0)
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  draftExecutionTasks      QuoteLineExecutionTask[]
  jobStageCopies           JobStage[]
  jobTaskCopies            JobTask[]

  @@index([quoteId])
  @@index([quoteId, executionOrder])
  @@index([sourceLineItemTemplateId])
}

/// Draft internal execution tasks for a quote line — independent from [LineItemTemplateTask] and [TaskTemplate] after copy.
model QuoteLineExecutionTask {
  id                           String                     @id @default(cuid())
  quoteLineItemId              String
  quoteLineItem                QuoteLineItem              @relation(fields: [quoteLineItemId], references: [id], onDelete: Cascade)
  sourceLineItemTemplateTaskId String?
  sourceLineItemTemplateTask   LineItemTemplateTask?      @relation(fields: [sourceLineItemTemplateTaskId], references: [id], onDelete: SetNull)
  sourceTaskTemplateId         String?
  sourceTaskTemplate           TaskTemplate?              @relation(fields: [sourceTaskTemplateId], references: [id], onDelete: SetNull)
  sourceType                   LineItemTemplateTaskSource
  title                        String
  stageKey                     ExecutionStageKey
  category                     TaskTemplateCategory
  instructions                 String?
  sortOrder                    Int                        @default(0)
  createdAt                    DateTime                   @default(now())
  updatedAt                    DateTime                   @updatedAt
  jobTaskCopies                JobTask[]

  @@index([quoteLineItemId, stageKey, sortOrder])
  @@index([quoteLineItemId, sortOrder])
}

/// Runtime job materialized from an APPROVED [Quote] at activation time.
/// Job rows are independent copies — later quote/template edits do not mutate stages or tasks here.
/// One job per quote in V1 (enforced by [@@unique] on [quoteId]).
model Job {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  quoteId        String       @unique
  quote          Quote        @relation(fields: [quoteId], references: [id])
  customerId     String?
  customer       Customer?    @relation(fields: [customerId], references: [id])
  leadId         String?
  lead           Lead?        @relation(fields: [leadId], references: [id])
  title          String
  status         JobStatus    @default(ACTIVE)
  activatedAt    DateTime     @default(now())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  stages         JobStage[]
  tasks          JobTask[]
  issues         JobIssue[]
  paymentRequirements JobPaymentRequirement[]
  activities     JobActivity[]
  dailyJobLogs   DailyJobLog[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([customerId])
  @@index([leadId])
}

/// Stage on a job — either a SHARED canonical phase merging tasks from many quote lines,
/// or a SEPARATE_LINE_ITEM block scoped to one source quote line. V1 has no nested groups.
model JobStage {
  id                    String            @id @default(cuid())
  jobId                 String
  job                   Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  blockType             JobStageBlockType
  stageKey              ExecutionStageKey
  title                 String
  /// Position within the job — shared stages first by canonical stage order, then separate blocks; ties broken by block order then stage order.
  sortOrder             Int               @default(0)
  /// SHARED: null. SEPARATE_LINE_ITEM: source quote line id at activation; SetNull if the line is later removed.
  sourceQuoteLineItemId String?
  sourceQuoteLineItem   QuoteLineItem?    @relation(fields: [sourceQuoteLineItemId], references: [id], onDelete: SetNull)
  /// Stable label for separate-line-item blocks (line description at activation); null for shared stages.
  blockTitle            String?
  /// Position of the parent block among separate blocks (work order at activation); 0 for shared.
  blockSortOrder        Int               @default(0)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  tasks                 JobTask[]
  issues                JobIssue[]
  paymentRequirements   JobPaymentRequirement[]

  @@index([jobId])
  @@index([jobId, sortOrder])
  @@index([sourceQuoteLineItemId])
}

/// Runtime task on a job — copied from a quote line execution task at activation; later quote edits do not mutate this row.
/// Lineage fields use SetNull so source deletes do not orphan the runtime row.
model JobTask {
  id                             String                     @id @default(cuid())
  jobId                          String
  job                            Job                        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobStageId                     String
  jobStage                       JobStage                   @relation(fields: [jobStageId], references: [id], onDelete: Cascade)
  sourceQuoteLineItemId          String?
  sourceQuoteLineItem            QuoteLineItem?             @relation(fields: [sourceQuoteLineItemId], references: [id], onDelete: SetNull)
  sourceQuoteLineExecutionTaskId String?
  sourceQuoteLineExecutionTask   QuoteLineExecutionTask?    @relation(fields: [sourceQuoteLineExecutionTaskId], references: [id], onDelete: SetNull)
  sourceTaskTemplateId           String?
  sourceTaskTemplate             TaskTemplate?              @relation(fields: [sourceTaskTemplateId], references: [id], onDelete: SetNull)
  sourceType                     LineItemTemplateTaskSource
  title                          String
  category                       TaskTemplateCategory
  stageKey                       ExecutionStageKey
  instructions                   String?
  status                         JobTaskStatus              @default(TODO)
  sortOrder                      Int                        @default(0)
  createdAt                      DateTime                   @default(now())
  updatedAt                      DateTime                   @updatedAt
  issues                         JobIssue[]
  sourceJobIssueId               String?                    @unique
  sourceJobIssue                 JobIssue?                  @relation("IssueFollowUpTask", fields: [sourceJobIssueId], references: [id], onDelete: SetNull)

  @@index([jobId])
  @@index([jobStageId, sortOrder])
}

model JobIssue {
  id              String           @id @default(cuid())
  organizationId  String
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  jobId           String
  job             Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobStageId      String?
  jobStage        JobStage?        @relation(fields: [jobStageId], references: [id], onDelete: SetNull)
  jobTaskId       String?
  jobTask         JobTask?         @relation(fields: [jobTaskId], references: [id], onDelete: SetNull)
  createdByUserId String?
  createdByUser   User?            @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  type            JobIssueType
  severity        JobIssueSeverity @default(BLOCKS_WORK)
  status          JobIssueStatus   @default(OPEN)
  title           String
  description     String?
  resolutionNote  String?
  resolvedAt      DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  followUpTask    JobTask?         @relation("IssueFollowUpTask")

  @@index([organizationId])
  @@index([jobId])
  @@index([organizationId, status])
  @@index([organizationId, severity])
  @@index([jobTaskId])
  @@index([jobStageId])
}

enum JobIssueType {
  INSPECTION_FAIL
  MATERIAL_DELAY
  SITE_CONDITION
  CUSTOMER_CHANGE
  WEATHER
  SCHEDULE_SLIP
  PAYMENT_BLOCK
  SCOPE_CLARIFICATION
  INTERNAL_ERROR
  OTHER
}

enum JobIssueSeverity {
  BLOCKS_WORK
  DOES_NOT_BLOCK
}

enum JobIssueStatus {
  OPEN
  RESOLVED
  CANCELLED
}

enum JobPaymentRequirementStatus {
  PENDING
  DUE
  PAID
  WAIVED
  CANCELED
}

enum JobActivityType {
  ISSUE_CREATED
  ISSUE_RESOLVED
  ISSUE_FOLLOW_UP_TASK_CREATED
  PAYMENT_REQUIREMENT_CREATED
  PAYMENT_REQUIREMENT_PAID
  PAYMENT_REQUIREMENT_WAIVED
  PAYMENT_REQUIREMENT_CANCELED
}

model JobActivity {
  id             String          @id @default(cuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  jobId          String
  job            Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)
  actorUserId    String?
  actorUser      User?           @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  type           JobActivityType
  title          String
  details        String?
  entityType     String?
  entityId       String?
  metadataJson   Json?
  createdAt      DateTime        @default(now())

  @@index([organizationId])
  @@index([jobId])
  @@index([organizationId, createdAt])
  @@index([jobId, createdAt])
  @@index([entityType, entityId])
}

model DailyJobLog {
  id               String            @id @default(cuid())
  organizationId   String
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  jobId            String
  job              Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  /// Normalized to midnight for v1. Org-timezone-aware date handling can be improved later.
  logDate          DateTime
  summary          String            @db.Text
  internalNotes    String?
  status           DailyJobLogStatus @default(DRAFT)
  reviewedByUserId String?
  reviewedByUser   User?             @relation("ReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  reviewedAt       DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([jobId, logDate])
  @@index([organizationId])
  @@index([jobId])
  @@index([organizationId, logDate])
  @@index([jobId, logDate])
  @@index([status])
}

model JobPaymentRequirement {
  id                    String                      @id @default(cuid())
  organizationId        String
  organization          Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  jobId                 String
  job                   Job                         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  title                 String
  amountCents           Int?
  status                JobPaymentRequirementStatus @default(PENDING)
  requiredBeforeStageId String?
  requiredBeforeStage   JobStage?                   @relation(fields: [requiredBeforeStageId], references: [id], onDelete: SetNull)
  paidAt                DateTime?
  waivedAt              DateTime?
  canceledAt            DateTime?
  notes                 String?
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt

  @@index([organizationId])
  @@index([jobId])
  @@index([organizationId, status])
  @@index([requiredBeforeStageId])
}
