model Tag {
  id             String    @id @default(cuid())
  organizationId String
  name           String // Canonical display name
  color          String? // Optional hex code
  source         TagSource @default(USER_CREATED)
  status         TagStatus @default(ACTIVE)

  /// Alternative names that map to this canonical tag.
  aliases String[] @default([])

  /// @deprecated Unused cache — UI derives counts via Prisma `_count` relations. Do not write.
  usageCountLineItems Int @default(0)
  /// @deprecated Unused cache — UI derives counts via Prisma `_count` relations. Do not write.
  usageCountTasks     Int @default(0)

  /// Audit log of merge events: [{ from: "visit site", at: "2024-05-15" }]
  mergeHistory Json @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  /// Many-to-Many relations
  lineItemTemplates         LineItemTemplate[]         @relation("LineItemTemplateToTag")
  taskTemplates             TaskTemplate[]             @relation("TaskTemplateToTag")
  clarificationQuestionSets ClarificationQuestionSet[] @relation("ClarificationQuestionSetToTag")

  @@unique([organizationId, name])
}

