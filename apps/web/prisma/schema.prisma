model Quote {
  id                         String                   @id @default(cuid())
  organizationId             String
  customerId                 String?
  serviceLocationId          String?
  status                     QuoteStatus              @default(DRAFT)
  title                      String
  internalNotes              String?
  subtotalCents              Int                      @default(0)
  totalCents                 Int                      @default(0)
  createdAt                  DateTime                 @default(now())
  updatedAt                  DateTime                 @updatedAt
  customerDocumentTitle      String?
  lastSentEmailAt            DateTime?
  leadId                     String?
  revisionOfQuoteId          String?
  revisionNumber             Int                      @default(1)
  presentation               Json?
  attachments                Attachment[]
  job                        Job?
  customer                   Customer?                @relation(fields: [customerId], references: [id])
  lead                       Lead?                    @relation(fields: [leadId], references: [id])
  serviceLocation            CustomerServiceLocation? @relation("QuoteServiceLocation", fields: [serviceLocationId], references: [id], onDelete: SetNull)
  organization               Organization             @relation(fields: [organizationId], references: [id])
  changeRequests             QuoteChangeRequest[]     @relation("QuoteChangeRequestIssuedQuote")
  resultingForChangeRequests QuoteChangeRequest[]     @relation("QuoteChangeRequestResultingRevision")
  checkpoints                QuoteCheckpoint[]
  lineItems                  QuoteLineItem[]
  paymentSchedule            PaymentScheduleItem[]
  shareToken                 QuoteShareToken?
  revisionOfQuote            Quote?                   @relation("QuoteRevisionLineage", fields: [revisionOfQuoteId], references: [id], onDelete: SetNull)
  revisedQuotes              Quote[]                  @relation("QuoteRevisionLineage")
  executionPlan              QuoteExecutionPlan?
  executionPlanRevisions     ExecutionPlanRevision[]
  changeOrders               ChangeOrder[]
  scopeDecisions             QuoteScopeDecision[]
  signatureRequests          QuoteSignatureRequest[]

  @@index([organizationId])
  @@index([customerId])
  @@index([leadId])
  @@index([serviceLocationId])
  @@index([status])
  @@index([revisionOfQuoteId])
}

model QuoteShareToken {
