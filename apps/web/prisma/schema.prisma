  organizationId  String
  jobId           String
  userId          String
  permissionsJson Json
  status          JobCollaboratorStatus @default(ACTIVE)
  grantedAt       DateTime              @default(now())
  revokedAt       DateTime?
  expiresAt       DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  organization    Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  job             Job                   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([jobId, userId])
  @@index([organizationId, userId, status])
  @@index([organizationId, jobId, status])
  @@index([expiresAt])
}

model Lead {
  id                      String                    @id @default(cuid())
  organizationId          String
  customerId              String?
  serviceLocationId       String?
  status                  LeadStatus                @default(NEW)
  channel                 LeadChannel               @default(MANUAL)
  contact                 Json
  request                 Json
  address                 Json?
  signals                 Json?
  formDefinitionId        String?
  formSnapshot            Json?
  raw                     Json?
  assignedToId            String?
  publicClientKey         String?
  convertedAt             DateTime?
  closeReason             LeadCloseReason?
  followUpAt              DateTime?
  closedAt                DateTime?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  attachments             Attachment[]
  createdServiceLocations CustomerServiceLocation[] @relation("ServiceLocationCreatedFromLead")
  jobs                    Job[]
  customer                Customer?                 @relation(fields: [customerId], references: [id])
  serviceLocation         CustomerServiceLocation?  @relation("LeadServiceLocation", fields: [serviceLocationId], references: [id], onDelete: SetNull)
  organization            Organization              @relation(fields: [organizationId], references: [id])
  customFieldValues       LeadCustomFieldValue[]
  events                  LeadEvent[]
  visitRequests           LeadVisitRequest[]
  quotes                  Quote[]

  @@unique([organizationId, publicClientKey])
  @@index([organizationId, status])
  @@index([serviceLocationId])
