// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  OPEN
  QUALIFYING
  CONVERTED
  LOST
  ARCHIVED
}

enum LeadSource {
  PHONE
  EMAIL
  SMS
  WEBSITE
  PUBLIC_REQUEST_LINK
  REFERRAL
  WALK_IN
  MANUAL
  OTHER
}

enum QuoteStatus {
  DRAFT
  ARCHIVED
}

/// Hidden proof records at commitment moments — not a user-managed version system.
/// SEND checkpoints capture the customer-safe proposal projection; they are not execution or task sources.
enum QuoteCheckpointKind {
  SEND
}

model Organization {
  id                    String                 @id @default(cuid())
  name                  String
  /// Lowercase public handle for `/request/[slug]` — optional until configured.
  slug                  String?                @unique
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  customers             Customer[]
  leads                 Lead[]
  quotes                Quote[]
  lineItemTemplates     LineItemTemplate[]
  quoteCheckpoints      QuoteCheckpoint[]
  publicRequestSettings PublicRequestSettings?
}

/// V1 contractor-configurable copy for the Public Intake Form — not a form-builder schema.
model PublicRequestSettings {
  id                       String       @id @default(cuid())
  organizationId           String       @unique
  organization           Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  enabled                  Boolean      @default(true)
  formTitle                String       @default("Request service")
  introMessage             String?
  emergencyWarningText     String?
  submitButtonText         String       @default("Send request")
  /// JSON array of `{ "value": "slug-key", "label": "Customer label" }` — validated server-side.
  requestTypeOptionsJson   Json         @default("[]")
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt
}

model Customer {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  displayName    String
  companyName    String?
  email          String?
  phone          String?
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  leads          Lead[]
  quotes         Quote[]

  @@index([organizationId])
}

model Lead {
  id             String         @id @default(cuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  customerId     String?
  customer       Customer?      @relation(fields: [customerId], references: [id])
  status         LeadStatus     @default(OPEN)
  source         LeadSource     @default(MANUAL)
  sourceDetail   String?
  title          String
  contactName    String?
  email          String?
  phone          String?
  notes          String?
  convertedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  quotes         Quote[]

  @@index([organizationId])
  @@index([customerId])
  @@index([status])
  @@index([source])
}

model Quote {
  id               String         @id @default(cuid())
  organizationId   String
  organization     Organization   @relation(fields: [organizationId], references: [id])
  customerId       String?
  customer         Customer?      @relation(fields: [customerId], references: [id])
  leadId           String?
  lead             Lead?          @relation(fields: [leadId], references: [id])
  status                 QuoteStatus    @default(DRAFT)
  title                  String
  customerDocumentTitle  String?
  internalNotes          String?
  subtotalCents      Int            @default(0)
  totalCents         Int            @default(0)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  lineItems          QuoteLineItem[]
  checkpoints        QuoteCheckpoint[]

  @@index([organizationId])
  @@index([customerId])
  @@index([leadId])
  @@index([status])
}

/// Immutable staff-only proof of what the customer-facing proposal contained at a send moment.
/// Quote remains the editable working record; QuoteStatus is unchanged by recording a checkpoint.
/// Future runtime tasks and jobs must materialize from approved checkpoints + execution planning — not from SEND rows.
model QuoteCheckpoint {
  id                        String              @id @default(cuid())
  organizationId          String
  organization            Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  quoteId                   String
  quote                     Quote               @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  kind                      QuoteCheckpointKind
  sequence                  Int
  schemaVersion             Int
  snapshotJson              Json
  staffOnlyJson             Json?
  /// Quote row `updatedAt` at capture time — staff context for drift vs proof.
  quoteUpdatedAtAtCapture   DateTime?
  createdAt                 DateTime            @default(now())

  @@unique([quoteId, kind, sequence])
  @@index([organizationId])
  @@index([quoteId, kind])
}

/// Reusable commercial line presets for an organization. Applying copies values onto [QuoteLineItem];
/// quotes never read live template fields for pricing after insert.
model LineItemTemplate {
  id                       String          @id @default(cuid())
  organizationId         String
  organization           Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  description            String
  defaultQuantity        Decimal         @db.Decimal(18, 6)
  defaultUnitAmountCents Int
  defaultInternalNotes             String?
  defaultCustomerScopeTitle        String?
  defaultCustomerScopeDescription  String?
  defaultCustomerIncludedNotes     String?
  defaultCustomerExcludedNotes     String?
  defaultCustomerPresentationGroup String?
  archivedAt                       DateTime?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  quoteLineItems         QuoteLineItem[]

  @@index([organizationId])
  @@index([organizationId, archivedAt])
}

/// Line items are always loaded through [Quote] scoped by [Quote.organizationId].
/// No denormalized organizationId here—avoids redundant writes and drift.
model QuoteLineItem {
  id                       String             @id @default(cuid())
  quoteId                  String
  quote                    Quote              @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  sortOrder                Int                @default(0)
  description                 String
  customerScopeTitle          String?
  customerScopeDescription    String?
  customerIncludedNotes       String?
  customerExcludedNotes       String?
  customerPresentationGroup   String?
  quantity                    Decimal            @db.Decimal(18, 6)
  unitAmountCents             Int
  lineTotalCents              Int
  internalNotes               String?
  sourceLineItemTemplateId String?
  sourceLineItemTemplate   LineItemTemplate?  @relation(fields: [sourceLineItemTemplateId], references: [id], onDelete: SetNull)
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  @@index([quoteId])
  @@index([sourceLineItemTemplateId])
}
