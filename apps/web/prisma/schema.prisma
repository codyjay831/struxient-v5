model QuoteChangeRequest {
  id               String       @id @default(cuid())
  organizationId   String
  quoteId          String
  resultingQuoteId String?
  requiresVisit    Boolean      @default(false)
  token            String
  message          String
  submittedFromIp  String?
  userAgent        String?
  createdAt        DateTime     @default(now())
  resolvedAt       DateTime?
  resolvedByUserId String?
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  quote            Quote        @relation("QuoteChangeRequestIssuedQuote", fields: [quoteId], references: [id], onDelete: Cascade)
  resultingQuote   Quote?       @relation("QuoteChangeRequestResultingRevision", fields: [resultingQuoteId], references: [id], onDelete: SetNull)
  resolvedBy       User?        @relation(fields: [resolvedByUserId], references: [id])

  @@index([quoteId])
  @@index([organizationId, createdAt])
}

/// Immutable staff-only proof of what the customer-facing proposal contained at a commitment moment (send, acceptance).
/// Quote status advances with Send (→ SENT) and staff-recorded approval (→ APPROVED) in v1; checkpoints store commercial projection only.
/// Future runtime jobs materialize from approved commercial baseline plus internal execution planning — not from checkpoint rows alone.
model QuoteCheckpoint {
  id                      String                @id @default(cuid())
  organizationId          String
  quoteId                 String
  kind                    QuoteCheckpointKind
  sequence                Int
  schemaVersion           Int
  snapshotJson            Json
  staffOnlyJson           Json?
  /// Quote row `updatedAt` at capture time — staff context for drift vs proof.
  quoteUpdatedAtAtCapture DateTime?
  createdAt               DateTime              @default(now())
  source                  QuoteCheckpointSource @default(STAFF)
  organization            Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  quote                   Quote                 @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@unique([quoteId, kind, sequence])
  @@index([organizationId])
  @@index([quoteId, kind])
}

/// Standard Acceptance / Verified E-Sign signature request for a quote version.
model QuoteSignatureRequest {
  id                    String                          @id @default(cuid())
  organizationId        String
  quoteId               String
  mode                  QuoteSignatureMode
  provider              SignatureProvider               @default(STRUXIENT)
  status                QuoteSignatureRequestStatus     @default(DRAFT)
  requestedByUserId     String?
  customMessage         String?
  expiresAt             DateTime?
  sentAt                DateTime?
  acceptedAt            DateTime?
  declinedAt            DateTime?
  revokedAt             DateTime?
  failedAt              DateTime?
  frozenSnapshotJson    Json
  frozenSnapshotSha256  String
  sentPdfArtifactId     String?
  sentPdfSha256         String?
  finalPdfArtifactId    String?
  finalPdfSha256        String?
  auditPacketArtifactId String?
  auditPacketSha256     String?
  sendCheckpointId      String?
  approvalCheckpointId  String?
  createdAt             DateTime                        @default(now())
  updatedAt             DateTime                        @updatedAt
  organization          Organization                    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  quote                 Quote                           @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  recipients            QuoteSignatureRecipient[]
  events                QuoteSignatureEvent[]
  deliveries            QuoteSignatureDelivery[]
  artifacts             QuoteSignatureArtifact[]
  providerEnvelope      QuoteSignatureProviderEnvelope?

  @@index([organizationId])
  @@index([quoteId])
  @@index([status])
  @@index([quoteId, status])
}

/// Signer identity for a signature request — not a delivery attempt.
model QuoteSignatureRecipient {
  id                       String                        @id @default(cuid())
  organizationId           String
  signatureRequestId       String
  quoteId                  String
  status                   QuoteSignatureRecipientStatus @default(PENDING)
  recipientName            String?
  recipientEmail           String?
  recipientPhone           String?
  preferredDeliveryChannel SignatureDeliveryChannel?
  tokenHash                String                        @unique
  tokenExpiresAt           DateTime?
  tokenRevokedAt           DateTime?
  sentAt                   DateTime?
  deliveredAt              DateTime?
  lastViewedAt             DateTime?
  acceptedAt               DateTime?
  acceptedByName           String?
  acceptedConsentAt        DateTime?
  consentText              String?
  consentVersion           String?
  acceptedFromIp           String?
  acceptedUserAgent        String?
  declinedAt               DateTime?
  declineReason            String?
  createdAt                DateTime                      @default(now())
  updatedAt                DateTime                      @updatedAt
  organization             Organization                  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  signatureRequest         QuoteSignatureRequest         @relation(fields: [signatureRequestId], references: [id], onDelete: Cascade)
  deliveries               QuoteSignatureDelivery[]
  events                   QuoteSignatureEvent[]
  artifacts                QuoteSignatureArtifact[]

  @@index([organizationId])
  @@index([signatureRequestId])
  @@index([quoteId])
  @@index([tokenHash])
}

/// Append-only audit events for quote signature flows.
model QuoteSignatureEvent {
  id                 String                   @id @default(cuid())
  organizationId     String
  quoteId            String
  signatureRequestId String?
  recipientId        String?
  actorType          SignatureActorType
  actorUserId        String?
  eventType          QuoteSignatureEventType
  occurredAt         DateTime                 @default(now())
  ipAddress          String?
  userAgent          String?
  provider           SignatureProvider?
  providerEventId    String?
  metadataJson       Json?
  createdAt          DateTime                 @default(now())
  organization       Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  signatureRequest   QuoteSignatureRequest?   @relation(fields: [signatureRequestId], references: [id], onDelete: SetNull)
  recipient          QuoteSignatureRecipient? @relation(fields: [recipientId], references: [id], onDelete: SetNull)

  @@unique([provider, providerEventId])
  @@index([organizationId])
  @@index([quoteId, occurredAt])
  @@index([signatureRequestId, occurredAt])
  @@index([recipientId, occurredAt])
}

/// Delivery attempt for a signer (email/SMS) — channel lives here, not on recipient.
model QuoteSignatureDelivery {
  id                 String                   @id @default(cuid())
  organizationId     String
  quoteId            String
  signatureRequestId String
  recipientId        String
  channel            SignatureDeliveryChannel
  provider           String
  providerMessageId  String?
  destinationMasked  String
  status             String
  attemptedAt        DateTime                 @default(now())
  completedAt        DateTime?
  errorCode          String?
  errorMessage       String?
  metadataJson       Json?
  organization       Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  signatureRequest   QuoteSignatureRequest    @relation(fields: [signatureRequestId], references: [id], onDelete: Cascade)
  recipient          QuoteSignatureRecipient  @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([signatureRequestId])
  @@index([recipientId])
  @@index([providerMessageId])
}

/// Signature artifact linkage with content hash.
model QuoteSignatureArtifact {
  id                 String                     @id @default(cuid())
  organizationId     String
  quoteId            String
  signatureRequestId String
  recipientId        String?
  attachmentId       String
  kind               QuoteSignatureArtifactKind
  sha256             String
  generatedAt        DateTime                   @default(now())
  metadataJson       Json?
  organization       Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  signatureRequest   QuoteSignatureRequest      @relation(fields: [signatureRequestId], references: [id], onDelete: Cascade)
  recipient          QuoteSignatureRecipient?   @relation(fields: [recipientId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([quoteId])
  @@index([signatureRequestId])
  @@index([attachmentId])
}

/// Provider-ready envelope storage for Verified E-Sign (DocuSign etc.).
model QuoteSignatureProviderEnvelope {
  id                 String                @id @default(cuid())
  organizationId     String
  quoteId            String
  signatureRequestId String                @unique
  provider           SignatureProvider
  providerEnvelopeId String
  providerStatus     String
  providerUrl        String?
  lastWebhookAt      DateTime?
  completedAt        DateTime?
  voidedAt           DateTime?
  metadataJson       Json?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  organization       Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  signatureRequest   QuoteSignatureRequest @relation(fields: [signatureRequestId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([provider, providerEnvelopeId])
}

model ChangeOrderCheckpoint {
  id                            String                      @id @default(cuid())
  organizationId                String
  changeOrderId                 String
  kind                          ChangeOrderCheckpointKind
  sequence                      Int
  schemaVersion                 Int
  snapshotJson                  Json
  staffOnlyJson                 Json?
  changeOrderUpdatedAtAtCapture DateTime?
  createdAt                     DateTime                    @default(now())
  source                        ChangeOrderCheckpointSource @default(STAFF)
  organization                  Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  changeOrder                   ChangeOrder                 @relation(fields: [changeOrderId], references: [id], onDelete: Cascade)

  @@unique([changeOrderId, kind, sequence])
  @@index([organizationId])
  @@index([changeOrderId, kind])
}

/// Reusable commercial line presets for an organization. Applying copies values onto [QuoteLineItem];
/// quotes never read live template fields for pricing after insert.
model LineItemTemplate {
  id                               String                 @id @default(cuid())
  organizationId                   String
  description                      String
  defaultQuantity                  Decimal                @db.Decimal(18, 6)
  defaultUnitAmountCents           Int
  defaultInternalNotes             String?
  archivedAt                       DateTime?
  createdAt                        DateTime               @default(now())
  updatedAt                        DateTime               @updatedAt
  defaultCustomerExcludedNotes     String?
  defaultCustomerIncludedNotes     String?
  defaultCustomerPresentationGroup String?
  defaultCustomerScopeDescription  String?
  defaultCustomerScopeTitle        String?
  priceBufferPercentage            Int                    @default(0)
  tags                             Tag[]                  @relation("LineItemTemplateToTag")
  organization                     Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  defaultExecutionTasks            LineItemTemplateTask[]
  quoteLineItems                   QuoteLineItem[]

  @@index([organizationId])
  @@index([organizationId, archivedAt])
}

/// Org-scoped reusable task presets (library). Quote/job rows copy fields from templates when applied — not live-linked.
model TaskTemplate {
  id                      String                   @id @default(cuid())
  organizationId          String
  title                   String
  category                TaskTemplateCategory
  instructions            String?
  archivedAt              DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  requirementsJson        Json                     @default("{}")
  /// Reserved for future assignment logic.
  assigneeRole            StaffRole?
  /// Reserved for future job costing.
  costBudgetCents         Int?
  /// Reserved for future estimation logic.
  estimatedMinutes        Int?
  hardSignal              Boolean                  @default(false)
  /// Reserved for future parts/materials logic.
  partsRequiredJson       Json?
  providesSignals         String[]                 @default([])
  requiresSignals         String[]                 @default([])
  tags                    Tag[]                    @relation("TaskTemplateToTag")
  stageId                 String?
  jobTaskCopies           JobTask[]
  lineItemTemplateTasks   LineItemTemplateTask[]
  quoteLineExecutionTasks QuoteLineExecutionTask[]
  quoteExecutionTasks     QuoteExecutionTask[]
  organization            Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stage                   Stage?                   @relation(fields: [stageId], references: [id])

  @@index([organizationId])
  @@index([organizationId, archivedAt])
}

/// Optional default execution on a saved line item — snapshot fields; not live-linked to [TaskTemplate] or quotes.
model LineItemTemplateTask {
  id                   String                     @id @default(cuid())
  lineItemTemplateId   String
  sourceType           LineItemTemplateTaskSource
  sourceTaskTemplateId String?
  title                String
  category             TaskTemplateCategory
  instructions         String?
  sortOrder            Int                        @default(0)
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  requirementsJson     Json                       @default("{}")
  /// Reserved for future assignment logic.
  assigneeRole         StaffRole?
  /// Reserved for future job costing.
  costBudgetCents      Int?
  /// Reserved for future estimation logic.
  estimatedMinutes     Int?
  hardSignal           Boolean                    @default(false)
  /// Reserved for future parts/materials logic.
  partsRequiredJson    Json?
  providesSignals      String[]                   @default([])
  requiresSignals      String[]                   @default([])
  stageId              String?
  lineItemTemplate     LineItemTemplate           @relation(fields: [lineItemTemplateId], references: [id], onDelete: Cascade)
  sourceTaskTemplate   TaskTemplate?              @relation(fields: [sourceTaskTemplateId], references: [id])
  stage                Stage?                     @relation(fields: [stageId], references: [id])
  quoteLineCopies      QuoteLineExecutionTask[]
  quoteExecutionCopies QuoteExecutionTask[]

  @@index([lineItemTemplateId, sortOrder])
}

/// Line items are always loaded through [Quote] scoped by [Quote.organizationId].
/// No denormalized organizationId here—avoids redundant writes and drift.
model QuoteLineItem {
  id                        String                    @id @default(cuid())
  quoteId                   String
  sortOrder                 Int                       @default(0)
  description               String
  quantity                  Decimal                   @db.Decimal(18, 6)
  unitAmountCents           Int
  lineTotalCents            Int
  internalNotes             String?
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
  sourceLineItemTemplateId  String?
  customerExcludedNotes     String?
  customerIncludedNotes     String?
  customerPresentationGroup String?
  customerScopeDescription  String?
  customerScopeTitle        String?
  executionRelevant         Boolean                   @default(true)
  jobStageCopies            JobStage[]
  jobTaskCopies             JobTask[]
  draftExecutionTasks       QuoteLineExecutionTask[]
  clarifications            QuoteLineClarification[]
  quote                     Quote                     @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  sourceLineItemTemplate    LineItemTemplate?         @relation(fields: [sourceLineItemTemplateId], references: [id])
  quoteExecutionTaskScopes  QuoteExecutionTaskScope[]
  jobScopeItems             JobScopeItem[]
  scopeDecisions            QuoteScopeDecision[]

  @@index([quoteId])
  @@index([sourceLineItemTemplateId])
}

/// Open scope decision — durable missing-info / unresolved scope question on a quote.
model QuoteScopeDecision {
  id                        String                              @id @default(cuid())
  organizationId            String
  quoteId                   String
  quoteLineItemId           String?
  sourceType                QuoteScopeDecisionSourceType
  title                     String
  detail                    String?
  status                    QuoteScopeDecisionStatus            @default(OPEN)
  resolutionTiming          QuoteScopeDecisionResolutionTiming?
  quoteImpact               QuoteScopeDecisionQuoteImpact       @default(NONE)
  sourceRefType             String?
  sourceRefId               String?
  resolvedByClarificationId String?
  createdByUserId           String?
  resolvedByUserId          String?
  createdAt                 DateTime                            @default(now())
  updatedAt                 DateTime                            @updatedAt
  resolvedAt                DateTime?
  quote                     Quote                               @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  quoteLineItem             QuoteLineItem?                      @relation(fields: [quoteLineItemId], references: [id], onDelete: Cascade)

  @@index([organizationId, quoteId])
  @@index([quoteId, status])
  @@index([quoteLineItemId])
  @@index([organizationId, quoteId, quoteLineItemId, sourceType])
}

/// Org-scoped reusable scope clarification set with versioned questions/options.
model ClarificationQuestionSet {
  id             String                         @id @default(cuid())
  organizationId String
  key            String
  version        Int
  label          String
  status         ClarificationQuestionSetStatus @default(draft)
  description    String?
  aliases        String[]                       @default([])
  keywords       String[]                       @default([])
  archivedAt     DateTime?
  mergedIntoId   String?
  createdAt      DateTime                       @default(now())
  updatedAt      DateTime                       @updatedAt
  organization   Organization                   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  mergedInto     ClarificationQuestionSet?      @relation("ClarificationQuestionSetMerge", fields: [mergedIntoId], references: [id])
  mergedFrom     ClarificationQuestionSet[]     @relation("ClarificationQuestionSetMerge")
  questions      ClarificationQuestion[]
  tags           Tag[]                          @relation("ClarificationQuestionSetToTag")
  lineAnswers    QuoteLineClarification[]

  @@unique([organizationId, key, version])
  @@index([organizationId])
  @@index([organizationId, key])
  @@index([organizationId, status])
}

model ClarificationQuestion {
  id             String                   @id @default(cuid())
  questionSetId  String
  key            String
  label          String
  inputType      ClarificationInputType
  helpText       String?
  allowOther     Boolean                  @default(false)
  unit           String?
  customerFacing Boolean                  @default(false)
  sortOrder      Int                      @default(0)
  aliases        String[]                 @default([])
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  questionSet    ClarificationQuestionSet @relation(fields: [questionSetId], references: [id], onDelete: Cascade)
  options        ClarificationOption[]

  @@unique([questionSetId, key])
  @@index([questionSetId, sortOrder])
}

model ClarificationOption {
  id         String                @id @default(cuid())
  questionId String
  key        String
  label      String
  aliases    String[]              @default([])
  sortOrder  Int                   @default(0)
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  question   ClarificationQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, key])
  @@index([questionId, sortOrder])
}

/// Durable per-line clarification answers with version-safe snapshots.
model QuoteLineClarification {
  id                 String                    @id @default(cuid())
  quoteLineItemId    String
  clarificationSetId String?
  questionSetKey     String
  questionSetVersion Int
  answersJson        Json
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  quoteLineItem      QuoteLineItem             @relation(fields: [quoteLineItemId], references: [id], onDelete: Cascade)
  clarificationSet   ClarificationQuestionSet? @relation(fields: [clarificationSetId], references: [id], onDelete: SetNull)

  @@unique([quoteLineItemId, questionSetKey, questionSetVersion])
  @@index([quoteLineItemId])
  @@index([questionSetKey, questionSetVersion])
}

/// Draft internal execution tasks for a quote line — independent from [LineItemTemplateTask] and [TaskTemplate] after copy.
model QuoteLineExecutionTask {
  id                           String                     @id @default(cuid())
  quoteLineItemId              String
  sourceLineItemTemplateTaskId String?
  sourceTaskTemplateId         String?
  sourceType                   LineItemTemplateTaskSource
  title                        String
  category                     TaskTemplateCategory
  instructions                 String?
  sortOrder                    Int                        @default(0)
  createdAt                    DateTime                   @default(now())
  updatedAt                    DateTime                   @updatedAt
  requirementsJson             Json                       @default("{}")
  /// Reserved for future assignment logic.
  assigneeRole                 StaffRole?
  /// Reserved for future job costing.
  costBudgetCents              Int?
  /// Reserved for future estimation logic.
  estimatedMinutes             Int?
  hardSignal                   Boolean                    @default(false)
  /// Reserved for future parts/materials logic.
  partsRequiredJson            Json?
  providesSignals              String[]                   @default([])
  requiresSignals              String[]                   @default([])
  stageId                      String?
  jobTaskCopies                JobTask[]
  quoteLineItem                QuoteLineItem              @relation(fields: [quoteLineItemId], references: [id], onDelete: Cascade)
  sourceLineItemTemplateTask   LineItemTemplateTask?      @relation(fields: [sourceLineItemTemplateTaskId], references: [id])
  sourceTaskTemplate           TaskTemplate?              @relation(fields: [sourceTaskTemplateId], references: [id])
  stage                        Stage?                     @relation(fields: [stageId], references: [id])
  quoteExecutionTaskCopies     QuoteExecutionTask[]

  @@index([quoteLineItemId, sortOrder])
}

model QuoteExecutionPlan {
  id                         String                   @id @default(cuid())
  organizationId             String
  quoteId                    String                   @unique
  status                     QuoteExecutionPlanStatus @default(DRAFT)
  planVersion                Int                      @default(1)
  planningInputHash          String?
  planningInputSchemaVersion Int                      @default(1)
  acceptedByUserId           String?
  acceptedAt                 DateTime?
  createdAt                  DateTime                 @default(now())
  updatedAt                  DateTime                 @updatedAt
  organization               Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  quote                      Quote                    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  acceptedByUser             User?                    @relation("QuoteExecutionPlanAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: SetNull)
  tasks                      QuoteExecutionTask[]

  @@index([organizationId])
  @@index([status])
}

model QuoteExecutionTask {
  id                             String                     @id @default(cuid())
  organizationId                 String
  quoteExecutionPlanId           String
  sourceLineItemTemplateTaskId   String?
  sourceQuoteLineExecutionTaskId String?
  sourceTaskTemplateId           String?
  sourceType                     LineItemTemplateTaskSource
  origin                         ExecutionTaskOrigin        @default(MANUAL)
  title                          String
  category                       TaskTemplateCategory
  instructions                   String?
  sortOrder                      Int                        @default(0)
  createdAt                      DateTime                   @default(now())
  updatedAt                      DateTime                   @updatedAt
  humanEditedAt                  DateTime?
  protectedAt                    DateTime?
  createdByPlanRevisionId        String?
  requirementsJson               Json                       @default("{}")
  assigneeRole                   StaffRole?
  costBudgetCents                Int?
  estimatedMinutes               Int?
  hardSignal                     Boolean                    @default(false)
  partsRequiredJson              Json?
  providesSignals                String[]                   @default([])
  requiresSignals                String[]                   @default([])
  planningTags                   String[]                   @default([])
  stageId                        String?
  organization                   Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  quoteExecutionPlan             QuoteExecutionPlan         @relation(fields: [quoteExecutionPlanId], references: [id], onDelete: Cascade)
  sourceLineItemTemplateTask     LineItemTemplateTask?      @relation(fields: [sourceLineItemTemplateTaskId], references: [id], onDelete: SetNull)
  sourceQuoteLineExecutionTask   QuoteLineExecutionTask?    @relation(fields: [sourceQuoteLineExecutionTaskId], references: [id], onDelete: SetNull)
  sourceTaskTemplate             TaskTemplate?              @relation(fields: [sourceTaskTemplateId], references: [id], onDelete: SetNull)
  stage                          Stage?                     @relation(fields: [stageId], references: [id], onDelete: SetNull)
  scopes                         QuoteExecutionTaskScope[]
  jobTaskCopies                  JobTask[]                  @relation("JobTaskSourceQuoteExecutionTask")

  @@index([organizationId])
  @@index([quoteExecutionPlanId, sortOrder])
  @@index([createdByPlanRevisionId])
  @@index([sourceQuoteLineExecutionTaskId])
}

model QuoteExecutionTaskScope {
  id                   String             @id @default(cuid())
  organizationId       String
  quoteExecutionTaskId String
  quoteLineItemId      String
  createdAt            DateTime           @default(now())
  organization         Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  quoteExecutionTask   QuoteExecutionTask @relation(fields: [quoteExecutionTaskId], references: [id], onDelete: Cascade)
  quoteLineItem        QuoteLineItem      @relation(fields: [quoteLineItemId], references: [id], onDelete: Cascade)

  @@unique([quoteExecutionTaskId, quoteLineItemId])
  @@index([organizationId])
  @@index([quoteLineItemId])
}

model ExecutionPlanRevision {
  id                    String                      @id @default(cuid())
  organizationId        String
  quoteId               String
  jobId                 String?
  changeOrderId         String?
  kind                  ExecutionPlanRevisionKind
  status                ExecutionPlanRevisionStatus @default(DRAFT)
  basePlanVersion       Int
  resultingPlanVersion  Int?
  proposalJson          Json
  proposalSchemaVersion Int
  plannerVersion        String
  modelProviderMeta     Json?
  planningInputHash     String?
  reasoningSummary      String?
  approvedByUserId      String?
  appliedAt             DateTime?
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt
  organization          Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  quote                 Quote                       @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  job                   Job?                        @relation(fields: [jobId], references: [id], onDelete: SetNull)
  changeOrder           ChangeOrder?                @relation(fields: [changeOrderId], references: [id], onDelete: SetNull)
  approvedByUser        User?                       @relation("ExecutionPlanRevisionApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([quoteId])
  @@index([jobId])
  @@index([changeOrderId])
}

model ChangeOrder {
  id                                        String                       @id @default(cuid())
  organizationId                            String
  quoteId                                   String
  jobId                                     String
  number                                    Int
  title                                     String
  customerDocumentTitle                     String?
  status                                    ChangeOrderStatus            @default(DRAFT)
  reasoning                                 String
  priceDeltaCents                           Int                          @default(0)
  approvedByUserId                          String?
  approvedAt                                DateTime?
  lastSentEmailAt                           DateTime?
  acceptedAt                                DateTime?
  appliedAt                                 DateTime?
  baseJobPlanVersion                        Int                          @default(1)
  executionDeltaJson                        Json?
  executionDeltaSchemaVersion               Int                          @default(1)
  applicationStatus                         ChangeOrderApplicationStatus @default(NOT_APPLIED)
  lastApplyErrorJson                        Json?
  lastApplyAttemptAt                        DateTime?
  supersededByChangeOrderId                 String?
  paymentImpactJson                         Json?
  zeroDollarPolicyClass                     ZeroDollarPolicyClass?
  internalNoCustomerImpactConfirmedAt       DateTime?
  internalNoCustomerImpactConfirmedByUserId String?
  createdAt                                 DateTime                     @default(now())
  updatedAt                                 DateTime                     @updatedAt
  organization                              Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  quote                                     Quote                        @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  job                                       Job                          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  approvedByUser                            User?                        @relation("ChangeOrderApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  internalNoCustomerImpactConfirmedByUser   User?                        @relation("ChangeOrderInternalNoCustomerImpactConfirmedBy", fields: [internalNoCustomerImpactConfirmedByUserId], references: [id], onDelete: SetNull)
  supersededByChangeOrder                   ChangeOrder?                 @relation("ChangeOrderSupersession", fields: [supersededByChangeOrderId], references: [id], onDelete: SetNull)
  supersedesChangeOrders                    ChangeOrder[]                @relation("ChangeOrderSupersession")
  lines                                     ChangeOrderLine[]
  executionPlanRevisions                    ExecutionPlanRevision[]
  paymentRequirements                       JobPaymentRequirement[]
  shareToken                                ChangeOrderShareToken?
  checkpoints                               ChangeOrderCheckpoint[]
  views                                     ChangeOrderView[]
  createdTasks                              JobTask[]

  @@unique([jobId, number])
  @@index([organizationId])
  @@index([quoteId])
  @@index([jobId])
  @@index([jobId, applicationStatus])
  @@index([supersededByChangeOrderId])
  @@index([zeroDollarPolicyClass])
  @@index([internalNoCustomerImpactConfirmedByUserId])
}

model ChangeOrderLine {
  id                     String                   @id @default(cuid())
  organizationId         String
  changeOrderId          String
  operation              ChangeOrderLineOperation
  sourceJobScopeItemId   String?
  description            String
  quantity               Decimal                  @db.Decimal(18, 6)
  unitPriceCents         Int?
  priceDeltaCents        Int?
  executionRelevant      Boolean                  @default(true)
  scopeDataJson          Json?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  organization           Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  changeOrder            ChangeOrder              @relation(fields: [changeOrderId], references: [id], onDelete: Cascade)
  sourceJobScopeItem     JobScopeItem?            @relation("ChangeOrderLineSourceScope", fields: [sourceJobScopeItemId], references: [id], onDelete: SetNull)
  resultingJobScopeItems JobScopeItem[]           @relation("JobScopeItemFromChangeOrderLine")

  @@index([organizationId])
  @@index([changeOrderId])
  @@index([sourceJobScopeItemId])
}

model PaymentScheduleItem {
  id            String                    @id @default(cuid())
  quoteId       String
  title         String // e.g. "Deposit", "Progress Payment", "Final Balance"
  amountCents   Int?
  percentage    Decimal?                  @db.Decimal(5, 2) // Optional: for % based schedules
  sortOrder     Int                       @default(0)
  // Anchor logic for execution gating
  anchorType    PaymentScheduleAnchorType @default(UPON_APPROVAL)
  anchorStageId String? // Link to a Stage in the library
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  quote         Quote                     @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  anchorStage   Stage?                    @relation(fields: [anchorStageId], references: [id])

  @@index([quoteId])
  @@index([quoteId, sortOrder])
}

/// Runtime job materialized from an APPROVED [Quote] at activation time.
/// Job rows are independent copies — later quote/template edits do not mutate stages or tasks here.
/// One job per quote in V1 (enforced by [@@unique] on [quoteId]).
model Job {
  id                     String                    @id @default(cuid())
  organizationId         String
  quoteId                String                    @unique
  customerId             String?
  serviceLocationId      String?
  title                  String
  status                 JobStatus                 @default(ACTIVE)
  activatedAt            DateTime                  @default(now())
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  leadId                 String?
  jobPlanVersion         Int                       @default(1)
  attachments            Attachment[]
  dailyJobLogs           DailyJobLog[]
  customer               Customer?                 @relation(fields: [customerId], references: [id])
  lead                   Lead?                     @relation(fields: [leadId], references: [id])
  serviceLocation        CustomerServiceLocation?  @relation("JobServiceLocation", fields: [serviceLocationId], references: [id], onDelete: SetNull)
  organization           Organization              @relation(fields: [organizationId], references: [id])
  quote                  Quote                     @relation(fields: [quoteId], references: [id])
  activities             JobActivity[]
  issues                 JobIssue[]
  recoveryFlows          JobRecoveryFlow[]
  paymentRequirements    JobPaymentRequirement[]
  signals                JobSignal[]
  stages                 JobStage[]
  tasks                  JobTask[]
  visits                 JobVisit[]
  scheduleEvents         JobScheduleEvent[]
  workPackages           JobWorkPackage[]
  scopeItems             JobScopeItem[]
  changeOrders           ChangeOrder[]
  executionPlanRevisions ExecutionPlanRevision[]
  collaborators          JobCollaborator[]
  portalAccesses         CustomerPortalAccess[]
  portalEvents           CustomerPortalEvent[]
  visibleResources       CustomerVisibleResource[]
  portalRequests         CustomerRequest[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([customerId])
  @@index([leadId])
  @@index([serviceLocationId])
}

/// Per-job fact bus for Signal-based readiness.
model JobSignal {
  id               String   @id @default(cuid())
  jobId            String
  name             String
  publishedAt      DateTime @default(now())
  /// Optional ID of the task that published this signal.
  sourceJobTaskId  String?
  /// Optional ID of the stage that published this signal.
  sourceJobStageId String?
  job              Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, name])
  @@index([jobId])
}

/// Stage on a job — materialized from the org-scoped Stage table at activation.
model JobStage {
  id                    String                  @id @default(cuid())
  jobId                 String
  title                 String
  /// Position within the job.
  sortOrder             Int                     @default(0)
  /// Source quote line id at activation; SetNull if the line is later removed.
  sourceQuoteLineItemId String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  providesSignals       String[]                @default([])
  requiresSignals       String[]                @default([])
  stageId               String?
  issues                JobIssue[]
  paymentRequirements   JobPaymentRequirement[]
  job                   Job                     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  sourceQuoteLineItem   QuoteLineItem?          @relation(fields: [sourceQuoteLineItemId], references: [id])
  stage                 Stage?                  @relation(fields: [stageId], references: [id])
  tasks                 JobTask[]

  @@index([jobId])
  @@index([jobId, sortOrder])
  @@index([sourceQuoteLineItemId])
}

/// Runtime task on a job — copied from a quote line execution task at activation; later quote edits do not mutate this row.
/// Lineage fields use SetNull so source deletes do not orphan the runtime row.
model JobTask {
  id                             String                     @id @default(cuid())
  jobId                          String
  jobStageId                     String
  sourceQuoteLineItemId          String?
  sourceQuoteLineExecutionTaskId String?
  sourceQuoteExecutionTaskId     String?
  sourceTaskTemplateId           String?
  sourceType                     LineItemTemplateTaskSource
  title                          String
  category                       TaskTemplateCategory
  instructions                   String?
  status                         JobTaskStatus              @default(TODO)
  sortOrder                      Int                        @default(0)
  createdAt                      DateTime                   @default(now())
  updatedAt                      DateTime                   @updatedAt
  sourceJobIssueId               String?
  recoveryFlowId                 String?
  recoveryFlowOrder              Int                        @default(0)
  completedAt                    DateTime?
  completedByUserId              String?
  canceledAt                     DateTime?
  canceledByUserId               String?
  canceledReason                 String?
  assignedUserId                 String?
  completionNote                 String?
  completionRequirementsJson     Json                       @default("{}")
  actualMinutes                  Int?
  dueAt                          DateTime?
  /// @deprecated Legacy calendar fields — use JobScheduleEvent after canonical cutover.
  scheduledStartAt               DateTime?
  /// @deprecated Legacy calendar fields — use JobScheduleEvent after canonical cutover.
  scheduledEndAt                 DateTime?
  /// @deprecated Replaced by dueMode + dueAnchor + dueOffsetDays.
  dueOffsetMinutesAfterReady     Int?
  dueMode                        TaskDueMode                @default(NONE)
  dueAnchor                      TaskDueAnchor?
  dueOffsetDays                  Int?
  dueGranularity                 TaskDueGranularity?
  dueResolvedAt                  DateTime?
  dueFirstReadyAt                DateTime?
  schedulingRequirement          TaskSchedulingRequirement  @default(NONE)
  workPackageId                  String?
  origin                         ExecutionTaskOrigin        @default(MANUAL)
  sourcePlanRevisionId           String?
  sourceChangeOrderId            String?
  sourceExecutionDeltaOpId       String?
  planningTags                   String[]                   @default([])
  /// Reserved for future assignment logic.
  assigneeRole                   StaffRole?
  /// Reserved for future job costing.
  costBudgetCents                Int?
  /// Reserved for future estimation logic.
  estimatedMinutes               Int?
  hardSignal                     Boolean                    @default(false)
  /// Reserved for future parts/materials logic.
  partsRequiredJson              Json?
  providesSignals                String[]                   @default([])
  requiresSignals                String[]                   @default([])
  stageId                        String?
  attachments                    Attachment[]
  issues                         JobIssue[]
  completedByUser                User?                      @relation("CompletedTasks", fields: [completedByUserId], references: [id])
  canceledByUser                 User?                      @relation("CanceledTasks", fields: [canceledByUserId], references: [id])
  assignedUser                   User?                      @relation("AssignedTasks", fields: [assignedUserId], references: [id])
  job                            Job                        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobStage                       JobStage                   @relation(fields: [jobStageId], references: [id], onDelete: Cascade)
  recoveryFlow                   JobRecoveryFlow?           @relation(fields: [recoveryFlowId], references: [id])
  sourceJobIssue                 JobIssue?                  @relation("IssueFollowUpTask", fields: [sourceJobIssueId], references: [id])
  sourceQuoteLineExecutionTask   QuoteLineExecutionTask?    @relation(fields: [sourceQuoteLineExecutionTaskId], references: [id])
  sourceQuoteExecutionTask       QuoteExecutionTask?        @relation("JobTaskSourceQuoteExecutionTask", fields: [sourceQuoteExecutionTaskId], references: [id], onDelete: SetNull)
  sourceQuoteLineItem            QuoteLineItem?             @relation(fields: [sourceQuoteLineItemId], references: [id])
  sourceTaskTemplate             TaskTemplate?              @relation(fields: [sourceTaskTemplateId], references: [id])
  sourceChangeOrder              ChangeOrder?               @relation(fields: [sourceChangeOrderId], references: [id], onDelete: SetNull)
  stage                          Stage?                     @relation(fields: [stageId], references: [id])
  scheduleEventLinks             JobScheduleEventTask[]
  workPackage                    JobWorkPackage?            @relation(fields: [workPackageId], references: [id], onDelete: SetNull)
  scopes                         JobTaskScope[]
  linkedCustomerRequests         CustomerRequest[]

  @@index([jobId])
  @@index([jobStageId, sortOrder])
  @@index([recoveryFlowId])
  @@index([assignedUserId])
  @@index([dueAt])
  @@index([scheduledStartAt])
  @@index([schedulingRequirement])
  @@index([workPackageId])
  @@index([sourceQuoteExecutionTaskId])
  @@index([sourceChangeOrderId])
}

model JobScopeItem {
  id                         String             @id @default(cuid())
  organizationId             String
  jobId                      String
  sourceQuoteLineItemId      String?
  sourceChangeOrderLineId    String?
  description                String
  quantity                   Decimal            @db.Decimal(18, 6)
  unitPriceCents             Int?
  executionRelevant          Boolean            @default(true)
  status                     JobScopeItemStatus @default(ACTIVE)
  supersededByJobScopeItemId String?            @unique
  createdAt                  DateTime           @default(now())
  updatedAt                  DateTime           @updatedAt
  organization               Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  job                        Job                @relation(fields: [jobId], references: [id], onDelete: Cascade)
  sourceQuoteLineItem        QuoteLineItem?     @relation(fields: [sourceQuoteLineItemId], references: [id], onDelete: SetNull)
  sourceChangeOrderLine      ChangeOrderLine?   @relation("JobScopeItemFromChangeOrderLine", fields: [sourceChangeOrderLineId], references: [id], onDelete: SetNull)
  supersededByJobScopeItem   JobScopeItem?      @relation("JobScopeItemSupersession", fields: [supersededByJobScopeItemId], references: [id], onDelete: SetNull)
  supersedesJobScopeItem     JobScopeItem?      @relation("JobScopeItemSupersession")
  sourceForChangeOrderLines  ChangeOrderLine[]  @relation("ChangeOrderLineSourceScope")
  taskScopes                 JobTaskScope[]

  @@index([organizationId])
  @@index([jobId])
  @@index([sourceQuoteLineItemId])
  @@index([sourceChangeOrderLineId])
}

model JobTaskScope {
  id             String       @id @default(cuid())
  organizationId String
  jobTaskId      String
  jobScopeItemId String
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  jobTask        JobTask      @relation(fields: [jobTaskId], references: [id], onDelete: Cascade)
  jobScopeItem   JobScopeItem @relation(fields: [jobScopeItemId], references: [id], onDelete: Cascade)

  @@unique([jobTaskId, jobScopeItemId])
  @@index([organizationId])
  @@index([jobScopeItemId])
}

model JobWorkPackage {
  id               String       @id @default(cuid())
  organizationId   String
  jobId            String
  title            String
  workType         String?
  plannedStartDate DateTime?
  plannedEndDate   DateTime?
  source           String?
  displayOrder     Int          @default(0)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  job              Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  tasks            JobTask[]

  @@index([organizationId])
  @@index([jobId])
  @@index([jobId, displayOrder])
}

/// Canonical job-related calendar commitment (appointment, crew block, inspection window, etc.).
model JobScheduleEvent {
  id                     String                             @id @default(cuid())
  organizationId         String
  jobId                  String
  kind                   JobScheduleEventKind
  status                 JobScheduleEventStatus             @default(TENTATIVE)
  completionOutcome      JobScheduleEventCompletionOutcome?
  completedAt            DateTime?
  title                  String?
  startAt                DateTime
  endAt                  DateTime
  externalWindowStartAt  DateTime?
  externalWindowEndAt    DateTime?
  externalWindowLabel    String?
  externalWindowNotes    String?
  externalWindowSource   String?
  customerVisible        Boolean                            @default(false)
  leadUserId             String?
  notes                  String?
  /// Bridge to legacy JobVisit row during migration; null for new-only events.
  legacyVisitId          String?                            @unique
  createdAt              DateTime                           @default(now())
  updatedAt              DateTime                           @updatedAt
  organization           Organization                       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  job                    Job                                @relation(fields: [jobId], references: [id], onDelete: Cascade)
  leadUser               User?                              @relation("LeadScheduleEvents", fields: [leadUserId], references: [id], onDelete: SetNull)
  taskLinks              JobScheduleEventTask[]
  linkedCustomerRequests CustomerRequest[]

  @@index([organizationId])
  @@index([jobId])
  @@index([leadUserId])
  @@index([status])
  @@index([completionOutcome])
  @@index([startAt])
  @@index([endAt])
}

model JobScheduleEventTask {
  id                 String           @id @default(cuid())
  jobScheduleEventId String
  jobTaskId          String
  createdAt          DateTime         @default(now())
  jobScheduleEvent   JobScheduleEvent @relation(fields: [jobScheduleEventId], references: [id], onDelete: Cascade)
  jobTask            JobTask          @relation(fields: [jobTaskId], references: [id], onDelete: Cascade)

  @@unique([jobScheduleEventId, jobTaskId])
  @@index([jobTaskId])
}

model JobIssue {
  id              String           @id @default(cuid())
  organizationId  String
  jobId           String
  jobStageId      String?
  jobTaskId       String?
  createdByUserId String?
  type            JobIssueType
  severity        JobIssueSeverity @default(BLOCKS_WORK)
  status          JobIssueStatus   @default(OPEN)
  title           String
  description     String?
  resolutionNote  String?
  resolvedAt      DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  createdByUser   User?            @relation(fields: [createdByUserId], references: [id])
  job             Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobStage        JobStage?        @relation(fields: [jobStageId], references: [id])
  jobTask         JobTask?         @relation(fields: [jobTaskId], references: [id])
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  followUpTasks   JobTask[]        @relation("IssueFollowUpTask")
  recoveryFlow    JobRecoveryFlow?

  @@index([organizationId])
  @@index([jobId])
  @@index([organizationId, status])
  @@index([organizationId, severity])
  @@index([jobTaskId])
  @@index([jobStageId])
}

model JobRecoveryFlow {
  id             String                @id @default(cuid())
  organizationId String
  jobId          String
  jobIssueId     String                @unique
  status         JobRecoveryFlowStatus @default(DRAFT)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  // Context fields for failure lineage
  sourceFailedTaskId      String?
  sourceChecklistItemId   String?
  sourcePermitEventId     String?
  sourceInspectionEventId String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  job          Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobIssue     JobIssue     @relation(fields: [jobIssueId], references: [id], onDelete: Cascade)
  tasks        JobTask[]

  @@index([organizationId])
  @@index([jobId])
  @@index([jobIssueId])
}

model JobVisit {
  id               String         @id @default(cuid())
  organizationId   String
  jobId            String
  scheduledStartAt DateTime
  scheduledEndAt   DateTime?
  status           JobVisitStatus @default(SCHEDULED)
  assignedUserId   String?
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  assignedUser     User?          @relation("AssignedVisits", fields: [assignedUserId], references: [id])
  job              Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([jobId])
  @@index([assignedUserId])
  @@index([status])
  @@index([scheduledStartAt])
}

model Attachment {
  id                     String            @id @default(cuid())
  organizationId         String
  fileName               String
  fileKey                String
  contentType            String
  fileSize               Int
  quoteId                String?
  jobId                  String?
  jobTaskId              String?
  uploadedByUserId       String?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  status                 AttachmentStatus  @default(READY)
  customerId             String?
  description            String?
  leadId                 String?
  customer               Customer?         @relation(fields: [customerId], references: [id])
  job                    Job?              @relation(fields: [jobId], references: [id])
  jobTask                JobTask?          @relation(fields: [jobTaskId], references: [id])
  lead                   Lead?             @relation(fields: [leadId], references: [id])
  organization           Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  quote                  Quote?            @relation(fields: [quoteId], references: [id])
  uploadedByUser         User?             @relation("UploadedAttachments", fields: [uploadedByUserId], references: [id])
  linkedCustomerRequests CustomerRequest[]

  @@index([organizationId])
  @@index([leadId])
  @@index([quoteId])
  @@index([jobId])
  @@index([jobTaskId])
  @@index([customerId])
}

model JobActivity {
  id             String          @id @default(cuid())
  organizationId String
  jobId          String
  actorUserId    String?
  type           JobActivityType
  title          String
  details        String?
  entityType     String?
  entityId       String?
  metadataJson   Json?
  createdAt      DateTime        @default(now())
  actorUser      User?           @relation(fields: [actorUserId], references: [id])
  job            Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([jobId])
  @@index([organizationId, createdAt])
  @@index([jobId, createdAt])
  @@index([entityType, entityId])
}

model DailyJobLog {
  id               String            @id @default(cuid())
  organizationId   String
  jobId            String
  /// Normalized to midnight for v1. Org-timezone-aware date handling can be improved later.
  logDate          DateTime
  summary          String
  internalNotes    String?
  status           DailyJobLogStatus @default(DRAFT)
  reviewedByUserId String?
  reviewedAt       DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  job              Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reviewedByUser   User?             @relation("ReviewedBy", fields: [reviewedByUserId], references: [id])

