generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                              String                           @id @default(cuid())
  name                            String
  createdAt                       DateTime                         @default(now())
  updatedAt                       DateTime                         @updatedAt
  /// Lowercase public handle for `/request/[slug]` — optional until configured.
  slug                            String?                          @unique
  /// IANA timezone for deadline date-only EOD resolution and schedule display.
  timezone                        String                           @default("America/Los_Angeles")
  attachments                     Attachment[]
  customers                       Customer[]
  customerServiceLocations        CustomerServiceLocation[]
  dailyJobLogs                    DailyJobLog[]
  intakeFormDefinitions           IntakeFormDefinition[]
  jobs                            Job[]
  jobActivities                   JobActivity[]
  jobIssues                       JobIssue[]
  jobRecoveryFlows                JobRecoveryFlow[]
  jobPaymentRequirements          JobPaymentRequirement[]
  jobVisits                       JobVisit[]
  jobScheduleEvents               JobScheduleEvent[]
  jobWorkPackages                 JobWorkPackage[]
  leads                           Lead[]
  leadCustomFieldDefs             LeadCustomFieldDef[]
  leadVisitRequests               LeadVisitRequest[]
  scheduleBlocks                  ScheduleBlock[]
  lineItemTemplates               LineItemTemplate[]
  memberships                     Membership[]
  publicRequestSettings           PublicRequestSettings?
  quotes                          Quote[]
  quoteExecutionPlans             QuoteExecutionPlan[]
  executionPlanRevisions          ExecutionPlanRevision[]
  changeOrders                    ChangeOrder[]
  changeOrderLines                ChangeOrderLine[]
  changeOrderShareTokens          ChangeOrderShareToken[]
  changeOrderCheckpoints          ChangeOrderCheckpoint[]
  changeOrderViews                ChangeOrderView[]
  jobScopeItems                   JobScopeItem[]
  jobTaskScopes                   JobTaskScope[]
  quoteExecutionTaskScopes        QuoteExecutionTaskScope[]
  quoteExecutionTasks             QuoteExecutionTask[]
  quoteChangeRequests             QuoteChangeRequest[]
  quoteCheckpoints                QuoteCheckpoint[]
  quoteShareTokens                QuoteShareToken[]
  quoteSignatureRequests          QuoteSignatureRequest[]
  quoteSignatureRecipients        QuoteSignatureRecipient[]
  quoteSignatureEvents            QuoteSignatureEvent[]
  quoteSignatureDeliveries        QuoteSignatureDelivery[]
  quoteSignatureArtifacts         QuoteSignatureArtifact[]
  quoteSignatureProviderEnvelopes QuoteSignatureProviderEnvelope[]
  notificationEvents              NotificationEvent[]
  stages                          Stage[]
  taskTemplates                   TaskTemplate[]
  tags                            Tag[]
  clarificationQuestionSets       ClarificationQuestionSet[]
  workstationSettings             WorkstationSettings?
  utilities                       Utility[]
  utilityCoverage                 UtilityCoverage[]
  jurisdictions                   Jurisdiction[]
  countyAssessorResources         CountyAssessorResource[]
  serviceLocationAudits           ServiceLocationAuditEvent[]
  siteDetailsReviews              SiteDetailsReview[]
  aiUsageLogs                     AiUsageLog[]
  businessProfile                 OrganizationBusinessProfile?
  organizationInvites             OrganizationInvite[]
  crews                           Crew[]
  crewMembers                     CrewMember[]
  jobCollaborators                JobCollaborator[]
  platformAuditEvents             PlatformAuditEvent[]
  billingAccount                  OrganizationBillingAccount?
  subscription                    OrganizationSubscription?
  aiBillingPeriods                AiBillingPeriod[]
  betaGrant                       OrganizationBetaGrant?
  betaSignupInvite                BetaSignupInvite?
  customerContacts                CustomerContact[]
  customerPortalAccesses          CustomerPortalAccess[]
  customerPortalEvents            CustomerPortalEvent[]
  customerVisibleResources        CustomerVisibleResource[]
  customerRequests                CustomerRequest[]
}

model Stage {
  id                      String                   @id @default(cuid())
  organizationId          String
  name                    String
  sortOrder               Int                      @default(0)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  archivedAt              DateTime?
  jobStages               JobStage[]
  jobTasks                JobTask[]
  lineItemTemplateTasks   LineItemTemplateTask[]
  quoteLineExecutionTasks QuoteLineExecutionTask[]
  quoteExecutionTasks     QuoteExecutionTask[]
  organization            Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  taskTemplates           TaskTemplate[]
  paymentScheduleItems    PaymentScheduleItem[]

  @@index([organizationId])
  @@index([organizationId, sortOrder])
}

model WorkstationSettings {
  id                   String       @id @default(cuid())
  organizationId       String       @unique
  showQuickActions     Boolean      @default(true)
  /// JSON array of visible action keys: ["new-intake", "new-quote", "browse-jobs"]
  quickActionsJson     Json         @default("[\"new-intake\", \"new-quote\", \"browse-jobs\"]")
  urgentThresholdHours Int          @default(24)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

/// V1 contractor-configurable copy for the Public Intake Form — not a form-builder schema.
model PublicRequestSettings {
  id                      String       @id @default(cuid())
  organizationId          String       @unique
  enabled                 Boolean      @default(true)
  formTitle               String       @default("Request service")
  introMessage            String?
  emergencyWarningText    String?
  submitButtonText        String       @default("Send request")
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
  /// JSON object mapping requestType value to array of LineItemTemplate ids: `{ "roof-repair": ["id1", "id2"] }`
  instantQuoteConfigJson  Json         @default("{}")
  instantQuoteEnabled     Boolean      @default(true)
  offerings               String[]     @default([])
  showInstantQuoteDetails Boolean      @default(true)
  organization            Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Customer {
  id               String                    @id @default(cuid())
  organizationId   String
  displayName      String
  companyName      String?
  email            String?
  phone            String?
  notes            String?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  attachments      Attachment[]
  organization     Organization              @relation(fields: [organizationId], references: [id])
  serviceLocations CustomerServiceLocation[]
  jobs             Job[]
  leads            Lead[]
  quotes           Quote[]
  contacts         CustomerContact[]
  portalAccesses   CustomerPortalAccess[]
  portalEvents     CustomerPortalEvent[]
  visibleResources CustomerVisibleResource[]
  portalRequests   CustomerRequest[]

  @@index([organizationId])
}

/// Person attached to a customer/property — contact context, not portal auth identity.
model CustomerContact {
  id                     String                 @id @default(cuid())
  organizationId         String
  customerId             String
  name                   String
  email                  String?
  phone                  String?
  relationshipToProperty String?
  isPrimary              Boolean                @default(false)
  isBillingContact       Boolean                @default(false)
  isDecisionMaker        Boolean                @default(false)
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  archivedAt             DateTime?
  organization           Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer               Customer               @relation(fields: [customerId], references: [id], onDelete: Cascade)
  portalAccesses         CustomerPortalAccess[]

  @@index([organizationId])
  @@index([customerId])
  @@index([organizationId, email])
  @@index([organizationId, phone])
}

/// Verified external customer portal identity — separate from staff User and CustomerContact.
model CustomerPortalIdentity {
  id              String                         @id @default(cuid())
  emailNormalized String?                        @unique
  phoneNormalized String?                        @unique
  emailVerifiedAt DateTime?
  phoneVerifiedAt DateTime?
  createdAt       DateTime                       @default(now())
  updatedAt       DateTime                       @updatedAt
  lastSeenAt      DateTime?
  disabledAt      DateTime?
  portalAccesses  CustomerPortalAccess[]
  sessions        CustomerPortalSession[]
  magicLinkTokens CustomerPortalMagicLinkToken[]
  portalEvents    CustomerPortalEvent[]

  @@index([disabledAt])
}

/// Scoped customer permission for organization + customer + job.
model CustomerPortalAccess {
  id                    String                         @id @default(cuid())
  organizationId        String
  customerId            String
  jobId                 String
  customerContactId     String?
  portalIdentityId      String?
  accessLevel           CustomerPortalAccessLevel      @default(PROJECT_PARTICIPANT)
  status                CustomerPortalAccessStatus     @default(PENDING_VERIFICATION)
  invitedByMembershipId String?
  revokedByMembershipId String?
  expiresAt             DateTime?
  createdAt             DateTime                       @default(now())
  updatedAt             DateTime                       @updatedAt
  revokedAt             DateTime?
  lastUsedAt            DateTime?
  organization          Organization                   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer              Customer                       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  job                   Job                            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  customerContact       CustomerContact?               @relation(fields: [customerContactId], references: [id], onDelete: SetNull)
  portalIdentity        CustomerPortalIdentity?        @relation(fields: [portalIdentityId], references: [id], onDelete: SetNull)
  invitedByMembership   Membership?                    @relation("PortalAccessInvitedBy", fields: [invitedByMembershipId], references: [id], onDelete: SetNull)
  revokedByMembership   Membership?                    @relation("PortalAccessRevokedBy", fields: [revokedByMembershipId], references: [id], onDelete: SetNull)
  sessions              CustomerPortalSession[]
  magicLinkTokens       CustomerPortalMagicLinkToken[]
  portalEvents          CustomerPortalEvent[]
  visibleResources      CustomerVisibleResource[]
  requests              CustomerRequest[]

  @@index([organizationId, customerId])
  @@index([organizationId, jobId])
  @@index([customerContactId])
  @@index([portalIdentityId])
  @@index([status])
  @@index([expiresAt])
}

model CustomerPortalSession {
  id                     String                 @id @default(cuid())
  portalIdentityId       String
  customerPortalAccessId String
  sessionTokenHash       String                 @unique
  createdAt              DateTime               @default(now())
  expiresAt              DateTime
  revokedAt              DateTime?
  lastSeenAt             DateTime?
  ipAddress              String?
  userAgent              String?
  portalIdentity         CustomerPortalIdentity @relation(fields: [portalIdentityId], references: [id], onDelete: Cascade)
  customerPortalAccess   CustomerPortalAccess   @relation(fields: [customerPortalAccessId], references: [id], onDelete: Cascade)

  @@index([portalIdentityId])
  @@index([customerPortalAccessId])
  @@index([expiresAt])
}

model CustomerPortalMagicLinkToken {
  id                     String                         @id @default(cuid())
  portalIdentityId       String?
  customerPortalAccessId String
  tokenHash              String                         @unique
  purpose                CustomerPortalMagicLinkPurpose
  createdAt              DateTime                       @default(now())
  expiresAt              DateTime
  usedAt                 DateTime?
  revokedAt              DateTime?
  ipAddress              String?
  userAgent              String?
  portalIdentity         CustomerPortalIdentity?        @relation(fields: [portalIdentityId], references: [id], onDelete: SetNull)
  customerPortalAccess   CustomerPortalAccess           @relation(fields: [customerPortalAccessId], references: [id], onDelete: Cascade)

  @@index([customerPortalAccessId])
  @@index([expiresAt])
  @@index([purpose])
}

model CustomerPortalEvent {
  id                     String                  @id @default(cuid())
  organizationId         String
  customerId             String
  jobId                  String?
  customerPortalAccessId String?
  portalIdentityId       String?
  eventType              CustomerPortalEventType
  resourceType           String?
  resourceId             String?
  metadataJson           Json?
  ipAddress              String?
  userAgent              String?
  createdAt              DateTime                @default(now())
  organization           Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer               Customer                @relation(fields: [customerId], references: [id], onDelete: Cascade)
  job                    Job?                    @relation(fields: [jobId], references: [id], onDelete: SetNull)
  customerPortalAccess   CustomerPortalAccess?   @relation(fields: [customerPortalAccessId], references: [id], onDelete: SetNull)
  portalIdentity         CustomerPortalIdentity? @relation(fields: [portalIdentityId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([customerId])
  @@index([jobId])
  @@index([customerPortalAccessId])
  @@index([eventType])
  @@index([createdAt])
}

model CustomerVisibleResource {
  id                     String                            @id @default(cuid())
  organizationId         String
  customerId             String
  jobId                  String
  resourceType           CustomerVisibleResourceType
  resourceId             String
  visibility             CustomerVisibleResourceVisibility @default(CUSTOMER_VISIBLE)
  visibleToAccessLevel   CustomerPortalAccessLevel?
  title                  String?
  description            String?
  createdByMembershipId  String?
  customerPortalAccessId String?
  createdAt              DateTime                          @default(now())
  updatedAt              DateTime                          @updatedAt
  revokedAt              DateTime?
  organization           Organization                      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer               Customer                          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  job                    Job                               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  customerPortalAccess   CustomerPortalAccess?             @relation(fields: [customerPortalAccessId], references: [id], onDelete: SetNull)
  createdByMembership    Membership?                       @relation("VisibleResourceCreatedBy", fields: [createdByMembershipId], references: [id], onDelete: SetNull)

  @@index([organizationId, jobId])
  @@index([customerId])
  @@index([resourceType, resourceId])
  @@index([visibility])
}

model CustomerRequest {
  id                     String                @id @default(cuid())
  organizationId         String
  customerId             String
  jobId                  String
  customerPortalAccessId String?
  type                   CustomerRequestType
  status                 CustomerRequestStatus @default(OPEN)
  title                  String
  message                String
  metadataJson           Json?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  resolvedAt             DateTime?
  resolvedByMembershipId String?
  linkedTaskId           String?
  linkedScheduleEventId  String?
  linkedDocumentId       String?
  organization           Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer               Customer              @relation(fields: [customerId], references: [id], onDelete: Cascade)
  job                    Job                   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  customerPortalAccess   CustomerPortalAccess? @relation(fields: [customerPortalAccessId], references: [id], onDelete: SetNull)
  resolvedByMembership   Membership?           @relation("CustomerRequestResolvedBy", fields: [resolvedByMembershipId], references: [id], onDelete: SetNull)
  linkedTask             JobTask?              @relation(fields: [linkedTaskId], references: [id], onDelete: SetNull)
  linkedScheduleEvent    JobScheduleEvent?     @relation(fields: [linkedScheduleEventId], references: [id], onDelete: SetNull)
  linkedDocument         Attachment?           @relation(fields: [linkedDocumentId], references: [id], onDelete: SetNull)

  @@index([organizationId, jobId])
  @@index([customerId])
  @@index([status])
  @@index([type])
}

/// Canonical service location record (legacy model name retained for safe additive migration).
model CustomerServiceLocation {
  id                     String                        @id @default(cuid())
  organizationId         String
  customerId             String?
  formattedAddress       String
  addressLine1           String                        @default("")
  addressLine2           String                        @default("")
  city                   String                        @default("")
  state                  String                        @default("")
  postalCode             String                        @default("")
  country                String                        @default("")
  googlePlaceId          String                        @default("")
  latitude               Float?
  longitude              Float?
  source                 CustomerServiceLocationSource
  /// Normalized deterministic key for dedup/reconciliation.
  addressFingerprint     String                        @default("")
  label                  String?
  isPrimary              Boolean                       @default(false)
  /// Set when property details must be re-reviewed due to material address edits.
  staleAt                DateTime?
  staleReason            String?
  apn                    String?
  apnSourceTitle         String?
  apnSourceUrl           String?
  apnDiscoveredAt        DateTime?
  apnResearchUsageLogId  String?
  apnVerificationUrl     String?
  apnConflictValue       String?
  apnConflictSourceTitle String?
  apnConflictSourceUrl   String?
  apnConflictDetectedAt  DateTime?
  utilityId              String?
  jurisdictionId         String?
  detailsStatus          SiteDetailsStatus             @default(UNVERIFIED)
  detailsSource          SiteDetailsSource             @default(DATABASE_MATCH)
  detailsLastChecked     DateTime?
  detailsReviewedAt      DateTime?
  detailsReviewedBy      String?
  createdAt              DateTime                      @default(now())
  updatedAt              DateTime                      @updatedAt
  createdFromLeadId      String?
  createdFromLead        Lead?                         @relation("ServiceLocationCreatedFromLead", fields: [createdFromLeadId], references: [id])
  customer               Customer?                     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  leads                  Lead[]                        @relation("LeadServiceLocation")
  quotes                 Quote[]                       @relation("QuoteServiceLocation")
  jobs                   Job[]                         @relation("JobServiceLocation")
  utility                Utility?                      @relation(fields: [utilityId], references: [id], onDelete: SetNull)
  jurisdiction           Jurisdiction?                 @relation(fields: [jurisdictionId], references: [id], onDelete: SetNull)
  auditEvents            ServiceLocationAuditEvent[]
  reviews                SiteDetailsReview[]
  aiUsageLogs            AiUsageLog[]
  organization           Organization                  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([customerId])
  @@index([customerId, isPrimary])
  @@index([createdFromLeadId])
  @@index([organizationId, addressFingerprint])
  @@index([organizationId, googlePlaceId])
  @@index([utilityId])
  @@index([jurisdictionId])
}

model User {
  id                                    String                        @id @default(cuid())
  email                                 String?                       @unique
  name                                  String?
  passwordHash                          String?
  createdAt                             DateTime                      @default(now())
  updatedAt                             DateTime                      @updatedAt
  emailVerified                         DateTime?
  termsAcceptedAt                       DateTime?
  termsVersion                          String?
  image                                 String?
  accounts                              Account[]
  uploadedAttachments                   Attachment[]                  @relation("UploadedAttachments")
  reviewedDailyJobLogs                  DailyJobLog[]                 @relation("ReviewedBy")
  jobActivities                         JobActivity[]
  jobIssues                             JobIssue[]
  completedTasks                        JobTask[]                     @relation("CompletedTasks")
  assignedTasks                         JobTask[]                     @relation("AssignedTasks")
  assignedVisits                        JobVisit[]                    @relation("AssignedVisits")
  leadScheduleEvents                    JobScheduleEvent[]            @relation("LeadScheduleEvents")
  scheduleBlocks                        ScheduleBlock[]
  notificationEvents                    NotificationEvent[]
  leadEvents                            LeadEvent[]
  memberships                           Membership[]
  resolvedChangeRequests                QuoteChangeRequest[]
  completedLeadVisits                   LeadVisitRequest[]            @relation("LeadVisitCompletedBy")
  assignedLeadVisits                    LeadVisitRequest[]            @relation("LeadVisitAssignedTo")
  sessions                              Session[]
  siteDetailsReviews                    SiteDetailsReview[]           @relation("SiteDetailsReviewedBy")
  serviceLocationAuditEvents            ServiceLocationAuditEvent[]   @relation("ServiceLocationAuditActor")
  updatedBusinessProfiles               OrganizationBusinessProfile[] @relation("BusinessProfileUpdatedBy")
  acceptedQuoteExecutionPlans           QuoteExecutionPlan[]          @relation("QuoteExecutionPlanAcceptedBy")
  approvedExecutionPlanRevisions        ExecutionPlanRevision[]       @relation("ExecutionPlanRevisionApprovedBy")
  approvedChangeOrders                  ChangeOrder[]                 @relation("ChangeOrderApprovedBy")
  confirmedNoCustomerImpactChangeOrders ChangeOrder[]                 @relation("ChangeOrderInternalNoCustomerImpactConfirmedBy")
  canceledTasks                         JobTask[]                     @relation("CanceledTasks")
  invitedOrganizationInvites            OrganizationInvite[]          @relation("OrganizationInviteInvitedBy")
  acceptedOrganizationInvites           OrganizationInvite[]          @relation("OrganizationInviteAcceptedBy")
  revokedOrganizationInvites            OrganizationInvite[]          @relation("OrganizationInviteRevokedBy")
  crewMemberships                       CrewMember[]
  jobCollaborations                     JobCollaborator[]
  lastActiveOrganizationId              String?
  platformAccess                        PlatformAccess?
  platformAccessCreated                 PlatformAccess[]              @relation("PlatformAccessCreatedBy")
  platformAccessRevoked                 PlatformAccess[]              @relation("PlatformAccessRevokedBy")
  platformAuditEvents                   PlatformAuditEvent[]          @relation("PlatformAuditActor")
  createdBetaSignupInvites              BetaSignupInvite[]            @relation("BetaSignupInviteCreatedBy")
  acceptedBetaSignupInvites             BetaSignupInvite[]            @relation("BetaSignupInviteAcceptedBy")
  revokedBetaSignupInvites              BetaSignupInvite[]            @relation("BetaSignupInviteRevokedBy")
  grantedBetaGrants                     OrganizationBetaGrant[]       @relation("OrganizationBetaGrantGrantedBy")
  revokedBetaGrants                     OrganizationBetaGrant[]       @relation("OrganizationBetaGrantRevokedBy")
}

model OrganizationBusinessProfile {
  id              String                          @id @default(cuid())
  organizationId  String                          @unique
  trades          BusinessProfileTrade[]          @default([])
  workTypes       BusinessProfileWorkType[]       @default([])
  customerMarkets BusinessProfileCustomerMarket[] @default([])
  operatingModel  BusinessProfileOperatingModel?
  teamSize        BusinessProfileTeamSize?
  updatedByUserId String?
  createdAt       DateTime                        @default(now())
  updatedAt       DateTime                        @updatedAt
  organization    Organization                    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  updatedByUser   User?                           @relation("BusinessProfileUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([updatedByUserId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Membership {
  id                       String                    @id @default(cuid())
  userId                   String
  organizationId           String
  role                     StaffRole                 @default(FIELD)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  organization             Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user                     User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitedPortalAccesses    CustomerPortalAccess[]    @relation("PortalAccessInvitedBy")
  revokedPortalAccesses    CustomerPortalAccess[]    @relation("PortalAccessRevokedBy")
  createdVisibleResources  CustomerVisibleResource[] @relation("VisibleResourceCreatedBy")
  resolvedCustomerRequests CustomerRequest[]         @relation("CustomerRequestResolvedBy")

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

enum BetaSignupInviteStatus {
  PENDING
  ACCEPTED
  REVOKED
}

model BetaSignupInvite {
  id               String                 @id @default(cuid())
  normalizedEmail  String
  tokenHash        String                 @unique
  status           BetaSignupInviteStatus @default(PENDING)
  betaDays         Int
  aiEnabled        Boolean                @default(false)
  aiIncludedUnits  Int                    @default(50)
  expiresAt        DateTime
  acceptedAt       DateTime?
  acceptedByUserId String?
  organizationId   String?                @unique
  revokedAt        DateTime?
  revokedByUserId  String?
  createdByUserId  String
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  createdBy        User                   @relation("BetaSignupInviteCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  acceptedBy       User?                  @relation("BetaSignupInviteAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: SetNull)
  revokedBy        User?                  @relation("BetaSignupInviteRevokedBy", fields: [revokedByUserId], references: [id], onDelete: SetNull)
  organization     Organization?          @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  betaGrant        OrganizationBetaGrant?

  @@index([normalizedEmail, status])
  @@index([expiresAt])
  @@index([status])
}

model OrganizationBetaGrant {
  id                 String            @id @default(cuid())
  organizationId     String            @unique
  betaSignupInviteId String?           @unique
  startsAt           DateTime          @default(now())
  expiresAt          DateTime
  aiEnabled          Boolean           @default(false)
  aiIncludedUnits    Int               @default(50)
  usedAiUnits        Int               @default(0)
  revokedAt          DateTime?
  revokedByUserId    String?
  grantedByUserId    String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  organization       Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  betaSignupInvite   BetaSignupInvite? @relation(fields: [betaSignupInviteId], references: [id], onDelete: SetNull)
  revokedBy          User?             @relation("OrganizationBetaGrantRevokedBy", fields: [revokedByUserId], references: [id], onDelete: SetNull)
  grantedBy          User?             @relation("OrganizationBetaGrantGrantedBy", fields: [grantedByUserId], references: [id], onDelete: SetNull)

  @@index([expiresAt])
  @@index([revokedAt])
}

model OrganizationInvite {
  id               String                   @id @default(cuid())
  organizationId   String
  normalizedEmail  String
  role             StaffRole
  tokenHash        String                   @unique
  status           OrganizationInviteStatus @default(PENDING)
  invitedByUserId  String
  acceptedByUserId String?
  expiresAt        DateTime
  acceptedAt       DateTime?
  revokedAt        DateTime?
  revokedByUserId  String?
  lastSentAt       DateTime?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  organization     Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy        User                     @relation("OrganizationInviteInvitedBy", fields: [invitedByUserId], references: [id], onDelete: Restrict)
  acceptedBy       User?                    @relation("OrganizationInviteAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: SetNull)
  revokedBy        User?                    @relation("OrganizationInviteRevokedBy", fields: [revokedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([normalizedEmail])
  @@index([expiresAt])
}

model Crew {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  archivedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members        CrewMember[]

  @@unique([organizationId, name])
  @@index([organizationId, archivedAt])
}

model CrewMember {
  id             String       @id @default(cuid())
  organizationId String
  crewId         String
  userId         String
  startsAt       DateTime?
  endsAt         DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  crew           Crew         @relation(fields: [crewId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([crewId, userId, startsAt])
  @@index([organizationId, userId])
  @@index([organizationId, crewId])
}

model JobCollaborator {
